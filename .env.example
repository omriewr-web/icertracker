# AtlasPM - Environment Variables
# Copy to .env.local and fill in your values

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# NextAuth - Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY="re_your_api_key_here"
RESEND_FROM_EMAIL="collections@yourdomain.com"

# Anthropic AI
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# Bootstrap Admin (created on first startup if missing)
BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
BOOTSTRAP_ADMIN_USERNAME="admin"
BOOTSTRAP_ADMIN_PASSWORD="change-me"

# App Config
NEXT_PUBLIC_APP_NAME="AtlasPM"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron/script auth for automated sync jobs
CRON_SECRET="your-cron-secret-here"

# Sentry Error Reporting
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn-here"
SENTRY_DSN="your-sentry-dsn-here"
SENTRY_AUTH_TOKEN="your-sentry-auth-token-here"
SENTRY_ORG="your-sentry-org-slug"
SENTRY_PROJECT="your-sentry-project-slug"

# NYC Open Data
NYC_OPEN_DATA_APP_TOKEN="your-nyc-open-data-token-here"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="your-supabase-url-here"
SUPABASE_URL="your-supabase-url-here"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key-here"

# Upstash Redis (rate limiting for public endpoints)
# Get from upstash.com → Create Database → REST API tab
UPSTASH_REDIS_REST_URL="your-upstash-redis-rest-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-rest-token"

# Logging
LOG_LEVEL="info"
