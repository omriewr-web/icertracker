  building          Building                   @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  assignedTo        User?                      @relation("TurnoverAssignee", fields: [assignedToUserId], references: [id])
  vendorAssignments TurnoverVendorAssignment[]

  @@index([unitId])
  @@index([buildingId])
  @@index([assignedToUserId])
  @@index([status])
  @@index([isActive])
  @@map("turnover_workflows")
}

model TurnoverVendorAssignment {
  id                 String               @id @default(cuid())
  turnoverWorkflowId String
  vendorId           String?
  vendorName         String
  trade              String // paint, plumbing, electric, hvac, flooring, general, cleaning, other
  status             TurnoverVendorStatus @default(PENDING)
  scheduledDate      DateTime?
  completedDate      DateTime?
  cost               Decimal?             @db.Decimal(10, 2)
  notes              String?              @db.Text
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  turnoverWorkflow TurnoverWorkflow @relation(fields: [turnoverWorkflowId], references: [id], onDelete: Cascade)
  vendor           Vendor?          @relation(fields: [vendorId], references: [id])

  @@index([turnoverWorkflowId])
  @@index([vendorId])
  @@map("turnover_vendor_assignments")
}

