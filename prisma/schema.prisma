  TEXTED
  EMAILED
  NOTICE_SENT
  PAYMENT_PLAN
  PARTIAL_PAYMENT
  PROMISE_TO_PAY
  SENT_TO_LEGAL
  OTHER
}

enum CollectionStatus {
  CURRENT
  LATE
  DELINQUENT
  CHRONIC
  PAYMENT_PLAN
  LEGAL
  VACATE_PENDING
}

model CollectionNote {
