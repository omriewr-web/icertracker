// ── Utility Meter & Account Compliance ───────────────────────────

model UtilityMeter {
  id             String   @id @default(cuid())
  buildingId     String
  unitId         String?
  utilityType    String // "electric" | "gas" | "water" | "common_electric" | "common_gas"
  providerName   String?
  meterNumber    String?
  serviceAddress String?
  isActive       Boolean  @default(true)
  classification String   @default("unit_submeter") // "unit_submeter" | "building_master" | "common_area" | "shared_meter"
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  building Building         @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit     Unit?            @relation(fields: [unitId], references: [id], onDelete: SetNull)
  accounts UtilityAccount[]

  @@index([buildingId])
  @@index([unitId])
  @@map("utility_meters")
}

model UtilityAccount {
  id                 String    @id @default(cuid())
  utilityMeterId     String
  accountNumber      String?
  assignedPartyType  String // "tenant" | "owner" | "management" | "unknown"
  assignedPartyName  String?
  tenantId           String?
  tenantNameSnapshot String? // Immutable snapshot of tenant name at account open
  leaseStartSnapshot DateTime? // Immutable snapshot of lease start at account open
  leaseEndSnapshot   DateTime? // Immutable snapshot of lease end at account open
  startDate          DateTime?
  endDate            DateTime?
  status             String    @default("active") // "active" | "closed" | "pending"
  closedWithBalance  Boolean?
  closeReason        String? // e.g. "tenant_moved_out", "account_transferred", "auto_closed_duplicate_cleanup"
  closedByUserId     String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  meter         UtilityMeter          @relation(fields: [utilityMeterId], references: [id], onDelete: Cascade)
  tenant        Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  monthlyChecks UtilityMonthlyCheck[]

  workflowState      String    @default("active_confirmed") // UtilityWorkflowState values as string

  @@index([utilityMeterId])
  @@index([tenantId])
  @@index([status])
  @@index([workflowState])
  @@map("utility_accounts")
}

model UtilityMonthlyCheck {
  id               String    @id @default(cuid())
  utilityAccountId String
  month            Int
  year             Int
  paymentStatus    String // "paid" | "unpaid" | "pending_verification" | "unknown" | "no_bill"
  verifiedBy       String?
  verifiedAt       DateTime?
  proofFileUrl     String?
  notes            String?
  createdAt        DateTime  @default(now())

  account UtilityAccount @relation(fields: [utilityAccountId], references: [id], onDelete: Cascade)

  @@unique([utilityAccountId, month, year])
  @@map("utility_monthly_checks")
}

