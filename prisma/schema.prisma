// ── Turnover Workflow ────────────────────────────────────────

enum TurnoverTrigger {
  MANUAL
  AUTO
}

enum TurnoverStatus {
  PENDING_INSPECTION
  INSPECTION_DONE
  SCOPE_CREATED
  VENDORS_ASSIGNED
  READY_TO_LIST
  LISTED
  COMPLETE
}

enum TurnoverVendorStatus {
  PENDING
  SCHEDULED
  COMPLETED
}

model TurnoverWorkflow {
  id                  String          @id @default(cuid())
  unitId              String
  buildingId          String
  triggeredBy         TurnoverTrigger @default(MANUAL)
  moveOutDate         DateTime?
  moveOutSource       String? // "LEASE_END" | "MANUAL"
  status              TurnoverStatus  @default(PENDING_INSPECTION)
  inspectionDate      DateTime?
  inspectionNotes     String?         @db.Text
  inspectionChecklist Json?
  scopeOfWork         String?         @db.Text
  estimatedCost       Decimal?        @db.Decimal(10, 2)
