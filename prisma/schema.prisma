// AtlasPM - Database Schema
// Stack: PostgreSQL via Supabase + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  ACCOUNT_ADMIN
  PM
  APM
  COLLECTOR
  OWNER
  LEASING_SPECIALIST
  BROKER
  SUPER
  ACCOUNTING
  LEASING_AGENT
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  name                String
  username            String              @unique
  passwordHash        String
  role                UserRole            @default(COLLECTOR)
  active              Boolean             @default(true)
  onboardingComplete  Boolean             @default(false)
  organizationId      String?
  managerId           String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  organization        Organization?       @relation(fields: [organizationId], references: [id])
  manager             User?               @relation("UserManager", fields: [managerId], references: [id])
  subordinates        User[]              @relation("UserManager")
  assignedProperties  UserProperty[]
  notes               TenantNote[]
  commLogs            CommLog[]
  payments            Payment[]
  legalNotes          LegalNote[]
  tasks               Task[]
  emails              EmailLog[]
  assignedWorkOrders  WorkOrder[]         @relation("WorkOrderAssignee")
  createdWorkOrders   WorkOrder[]         @relation("WorkOrderCreator")
  workOrderComments   WorkOrderComment[]
  assignedViolations  Violation[]
  assignedCollections CollectionCase[]    @relation("CollectionAssignee")
  assignedVacancies   Vacancy[]           @relation("VacancyAssignee")
  assignedLegalCases  LegalCase[]         @relation("LegalCaseAssignee")
  assignedInspections Inspection[]        @relation("InspectionAssignee")
  assignedMoveOuts    MoveOutAssessment[] @relation("MoveOutAssignee")
  activityEvents      ActivityEvent[]
  collectionNotes     CollectionNote[]
  assignedSignals     OperationalSignal[] @relation("SignalAssignee")
  acknowledgedSignals OperationalSignal[] @relation("SignalAcknowledger")
  resolvedSignals     OperationalSignal[] @relation("SignalResolver")
  scanLogs            SignalScanLog[]
  assignedTurnovers   TurnoverWorkflow[]  @relation("TurnoverAssignee")
  workOrderActivities WorkOrderActivity[] @relation("WorkOrderActivityUser")
  leasingActivities       LeasingActivity[]
  preparedCertPackets     CertificationPacket[] @relation("CertPacketPreparer")
  reviewedCertPackets     CertificationPacket[] @relation("CertPacketReviewer")
  pmVerifiedViolations    Violation[]           @relation("ViolationPMVerifier")
  prometheusIntakes       PrometheusIntake[]    @relation("PrometheusCreator")
  verifiedDrafts          WorkOrderDraft[]      @relation("DraftVerifier")
  collectionActionsLogged CollectionAction[]    @relation("CollectionActionStaff")

  // ── Permission system v2 fields ──
  permissionPreset     String    @default("property_manager")
  canExportSensitive   Boolean   @default(false)
  canDeleteRecords     Boolean   @default(false)
  canBulkUpdate        Boolean   @default(false)
  canManageUsers       Boolean   @default(false)
  canManageOrgSettings Boolean   @default(false)
  termsAcceptedAt      DateTime?
  termsAcceptedIp      String?
  accessGrants         UserAccessGrant[]

  @@index([organizationId])
  @@index([managerId])
  uploadedDocuments  Document[]
  preferences        UserPreferences?
  @@map("users")
}

model UserPreferences {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName            String?
  jobTitle               String?
  mobile                 String?
  timezone               String   @default("America/New_York")

  defaultView            String   @default("dashboard")

  briefingItems          String[] @default([])
  briefingTime           String   @default("morning")

  alertWorkOrderAssigned Boolean  @default(true)
  alertTenant30Days      Boolean  @default(true)
  alertTenant60Days      Boolean  @default(true)
  alertTenant90Days      Boolean  @default(true)
  alertViolationClassC   Boolean  @default(true)
  alertViolationAll      Boolean  @default(false)
  alertLeaseExpiring30   Boolean  @default(true)
  alertWorkOrderOverdue  Boolean  @default(true)
  alertChannel           String   @default("in_app")
  quietHoursEnabled      Boolean  @default(false)
  quietHoursStart        String?
  quietHoursEnd          String?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("user_preferences")
}

model UserAccessGrant {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId        String
  module       String
  level        String
  scopeType    String   @default("org")
  scopeId      String?
  restrictions Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, orgId, module, scopeType, scopeId])
  @@index([userId, orgId])
  @@map("user_access_grants")
}

model PermissionAuditLog {
  id           String   @id @default(cuid())
  orgId        String
  changedBy    String
  affectedUser String
  changeType   String
  oldValue     Json?
  newValue     Json?
  createdAt    DateTime @default(now())

  @@index([orgId, createdAt(sort: Desc)])
  @@index([affectedUser])
  @@map("permission_audit_logs")
}

model UserProperty {
  id         String   @id @default(cuid())
  userId     String
  buildingId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([userId, buildingId])
  @@map("user_properties")
}

model Building {
  id                String    @id @default(cuid())
  yardiId           String    @unique
  yardiCode         String?   @unique
  propertyId        String?   @unique
  buildingName      String?
  address           String
  altAddress        String?
  city              String?   @default("New York")
  state             String?   @default("NY")
  borough           String?
  entity            String?
  portfolio         String?
  region            String?
  zip               String?
  block             String?
  lot               String?
  bbl               String?
  type              String    @default("Residential")
  owner             String?
  ownerEmail        String?
  manager           String?
  managementCompany String?
  arTeam            String?
  apTeam            String?
  headPortfolio     String?
  mgmtStartDate     DateTime?
  einNumber         String?

  // DOB / Registration IDs
  bin                    String? // BIN # (DOB)
  mdrNumber              String? // MDR Number
  dhcrRegId              String? // DHCR Registration ID
  hpdRegistrationId      String?
  certificateOfOccupancy String?

  // Construction Details
  squareFootage     Int?
  yearBuilt         Int?
  constructionType  String?
  floors            Int?
  floorsBelowGround Int?
  buildingClass     String?

  // Building Status & Designations
  buildingStatus String  @default("active")
  rentStabilized Boolean @default(false)
  landmarkStatus String  @default("none")
  aepStatus      String  @default("none")

  // Mechanical Systems (scalar)
  boilerType        String?
  boilerInstallYear Int?
  hotWaterType      String?
  gasType           String?
  elevator          Boolean @default(false)
  elevatorCount     Int     @default(0)
  sprinklerSystem   Boolean @default(false)
  fireAlarmSystem   Boolean @default(false)
  oilTank           Boolean @default(false)

  // Life Safety Systems (JSON — legacy, still populated on import)
  lifeSafety      Json?
  // Elevator Info (JSON — legacy, still populated on import)
  elevatorInfo    Json?
  // Boiler Info (JSON — legacy, still populated on import)
  boilerInfo      Json?
  // Compliance Filing Dates (JSON)
  complianceDates Json?

  superintendent       Json?
  elevatorCompany      Json?
  fireAlarmCompany     Json?
  utilityMeters        Json?
  utilityAccounts      Json?
  totalUnits           Int                   @default(0)
  commercialUnits      Int                   @default(0)
  lastInspectionDate   DateTime?
  notes                String?
  publicAccessToken    String?               @unique
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  units                Unit[]
  assignedUsers        UserProperty[]
  importBatches        ImportBatch[]
  workOrders           WorkOrder[]
  maintenanceSchedules MaintenanceSchedule[]
  organizationId       String?
  ownerId              String?
  organization         Organization?         @relation(fields: [organizationId], references: [id])
  ownerRecord          Owner?                @relation(fields: [ownerId], references: [id])
  violations           Violation[]
  complianceItems      ComplianceItem[]
  violationSyncLogs    ViolationSyncLog[]
  legalCases           LegalCase[]
  collectionCases      CollectionCase[]
  vacancies            Vacancy[]
  inspections          Inspection[]
  inspectionItems      InspectionItem[]
  moveOutAssessments   MoveOutAssessment[]
  moveOutCharges       MoveOutCharge[]
  activityEvents       ActivityEvent[]
  complaints           Complaint[]
  collectionNotes      CollectionNote[]
  arSnapshots          ARSnapshot[]
  utilityMeterRecords  UtilityMeter[]
  turnoverWorkflows    TurnoverWorkflow[]
  leasingActivities    LeasingActivity[]
  riskScore            Float?
  riskCategory         String?
  lat                  Float?
  lng                  Float?

  leases                 Lease[]
  vendorAssignments      VendorAssignment[]
  riskSnapshots          RiskSnapshot[]
  certificationPackets   CertificationPacket[]
  prometheusIntakes      PrometheusIntake[]
  workOrderDrafts        WorkOrderDraft[]
  buildingVendors        BuildingVendor[]
  projects               Project[]

  @@index([organizationId])
  @@index([ownerId])
  @@index([portfolio])
  @@index([region])
  @@index([borough])
  @@index([bbl])
  @@index([block, lot])
  @@index([buildingStatus])
  documents        Document[]
  @@map("buildings")
}

model Unit {
  id                   String                @id @default(cuid())
  buildingId           String
  unitNumber           String
  unitType             String?
  unitCategory         String? // "residential", "commercial", "parking", "laundry", "super", "other"
  bedroomCount         Int?
  bathroomCount        Decimal?            @db.Decimal(3, 1)
  squareFeet           Int?
  legalRent            Decimal?              @db.Decimal(10, 2) // DHCR registered rent
  rentStabilized       Boolean               @default(false)
  askingRent           Decimal?              @db.Decimal(10, 2)
  isVacant             Boolean               @default(false)
  vacantSince          DateTime?
  vacancyStatus        VacancyStatus?
  statusChangedAt      DateTime?
  readyDate            DateTime?
  proposedRent         Decimal?              @db.Decimal(10, 2)
  approvedRent         Decimal?              @db.Decimal(10, 2)
  rentProposedBy       String?
  rentApprovedBy       String?
  rentProposedAt       DateTime?
  rentApprovedAt       DateTime?
  accessType           String?               // MASTER_KEY | SUPER | LOCKBOX | COMBINATION
  accessNotes          String?
  superName            String?
  superPhone           String?
  isResidential        Boolean               @default(true)
  // Rent regulation fields
  isRentControlled     Boolean               @default(false)
  regulationType       RegulationType        @default(UNKNOWN)
  dhcrRegistrationId   String?
  lastDhcrRegistrationYear Int?
  mciMonthlyIncrease   Decimal?              @db.Decimal(10, 2)
  mciExpirationDate    DateTime?
  unitRooms            Int?
  building             Building              @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  tenant               Tenant?
  vacancyInfo          VacancyInfo?
  workOrders           WorkOrder[]
  maintenanceSchedules MaintenanceSchedule[]
  leases               Lease[]
  violations           Violation[]
  legalCases           LegalCase[]
  collectionCases      CollectionCase[]
  vacancies            Vacancy[]
  inspections          Inspection[]
  inspectionItems      InspectionItem[]
  moveOutAssessments   MoveOutAssessment[]
  moveOutCharges       MoveOutCharge[]
  activityEvents       ActivityEvent[]
  complaints           Complaint[]
  utilityMeterRecords  UtilityMeter[]
  turnoverWorkflows    TurnoverWorkflow[]
  leasingActivities    LeasingActivity[]
  documents            Document[]

  @@unique([buildingId, unitNumber])
  @@index([vacancyStatus])
  @@index([buildingId, isVacant])
  @@map("units")
}

model Tenant {
  id                 String              @id @default(cuid())
  unitId             String              @unique
  yardiResidentId    String?             @unique
  name               String
  firstName          String?
  lastName           String?
  email              String?
  phone              String?
  marketRent         Decimal             @default(0) @db.Decimal(10, 2)
  legalRent          Decimal             @default(0) @db.Decimal(10, 2)
  dhcrLegalRent      Decimal             @default(0) @db.Decimal(10, 2)
  prefRent           Decimal             @default(0) @db.Decimal(10, 2)
  actualRent         Decimal             @default(0) @db.Decimal(10, 2)
  chargeCode         String?
  isStabilized       Boolean             @default(false)
  deposit            Decimal             @default(0) @db.Decimal(10, 2)
  moveInDate         DateTime?
  leaseExpiration    DateTime?
  moveOutDate        DateTime?
  balance            Decimal             @default(0) @db.Decimal(10, 2)
  arrearsCategory    String              @default("current")
  arrearsDays        Int                 @default(0)
  monthsOwed         Decimal             @default(0) @db.Decimal(5, 1)
  leaseStatus        String              @default("active")
  collectionScore    Int                 @default(0)
  // Rent stabilization tracking
  leaseType          TenantLeaseType     @default(UNKNOWN)
  rgbOrderApplied    String?
  iaiMonthlyIncrease Decimal?            @db.Decimal(10, 2)
  iaiStartDate       DateTime?
  overrides          Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  isDeleted          Boolean             @default(false)
  deletedAt          DateTime?
  unit               Unit                @relation(fields: [unitId], references: [id], onDelete: Restrict)
  notes              TenantNote[]
  commLogs           CommLog[]
  payments           Payment[]
  legalCases         LegalCase[]
  tasks              Task[]
  emails             EmailLog[]
  workOrders         WorkOrder[]
  leases             Lease[]
  balanceSnapshots   BalanceSnapshot[]
  collectionCases    CollectionCase[]
  moveOutAssessments MoveOutAssessment[]
  moveOutCharges     MoveOutCharge[]
  activityEvents     ActivityEvent[]
  collectionNotes    CollectionNote[]
  arSnapshots        ARSnapshot[]
  utilityAccounts      UtilityAccount[]
  paymentPlans         PaymentPlan[]
  collectionStage      CollectionStage?
  collectionActions    CollectionAction[]
  firstDelinquencyDate DateTime?

  @@index([balance])
  @@index([arrearsCategory])
  @@index([leaseExpiration])
  @@index([collectionScore])
  @@index([unitId, balance])
  @@index([isDeleted])
  documents          Document[]
  @@map("tenants")
}

enum NoteCategory {
  GENERAL
  COLLECTION
  PAYMENT
  LEGAL
  LEASE
  MAINTENANCE
}

model TenantNote {
  id        String       @id @default(cuid())
  tenantId  String
  authorId  String
  text      String       @db.Text
  category  NoteCategory @default(GENERAL)
  createdAt DateTime     @default(now())
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  author    User         @relation(fields: [authorId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([authorId])
  @@map("tenant_notes")
}

enum CommType {
  PHONE
  EMAIL
  LETTER
  IN_PERSON
  TEXT_MSG
  LEGAL_NOTICE
  OTHER
}

model CommLog {
  id        String   @id @default(cuid())
  tenantId  String
  authorId  String
  type      CommType
  summary   String   @db.Text
  outcome   String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  author    User     @relation(fields: [authorId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([authorId])
  @@map("comm_logs")
}

model Payment {
  id         String   @id @default(cuid())
  tenantId   String
  recordedBy String
  amount     Decimal  @db.Decimal(10, 2)
  date       DateTime
  method     String?
  reference  String?
  notes      String?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  recorder   User     @relation(fields: [recordedBy], references: [id])

  @@index([tenantId, date(sort: Desc)])
  @@index([recordedBy])
  @@map("payments")
}

enum LegalStage {
  NOTICE_SENT
  HOLDOVER
  NONPAYMENT
  COURT_DATE
  STIPULATION
  JUDGMENT
  WARRANT
  EVICTION
  SETTLED
}

model LegalCase {
  id                   String          @id @default(cuid())
  tenantId             String
  buildingId           String?
  unitId               String?
  collectionCaseId     String?
  attorneyId           String?
  assignedUserId       String?
  marshalId            String?
  inLegal              Boolean         @default(true)
  stage                LegalStage      @default(NOTICE_SENT)
  caseNumber           String?
  attorney             String?
  filedDate            DateTime?
  courtDate            DateTime?
  arrearsBalance       Decimal?        @db.Decimal(10, 2)
  status               String          @default("active") // active, settled, dismissed, withdrawn
  importBatchId        String?
  isActive             Boolean         @default(true)
  marshalScheduledDate DateTime?
  marshalExecutedDate  DateTime?
  notes_text           String?         @db.Text
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  building             Building?       @relation(fields: [buildingId], references: [id])
  unit                 Unit?           @relation(fields: [unitId], references: [id])
  collectionCase       CollectionCase? @relation(fields: [collectionCaseId], references: [id])
  attorneyContact      Vendor?         @relation("LegalCaseAttorney", fields: [attorneyId], references: [id])
  assignedUser         User?           @relation("LegalCaseAssignee", fields: [assignedUserId], references: [id])
  marshalContact       Vendor?         @relation("LegalCaseMarshal", fields: [marshalId], references: [id])
  notes                LegalNote[]

  @@index([tenantId])
  @@index([stage])
  @@index([status])
  @@index([buildingId])
  @@index([unitId])
  @@index([collectionCaseId])
  @@index([assignedUserId])
  @@index([attorneyId])
  @@index([marshalId])
  @@index([isActive])
  @@index([buildingId, isActive])
  @@map("legal_cases")
}

model LegalImportQueue {
  id                       String    @id @default(cuid())
  importBatchId            String
  rowIndex                 Int
  rawData                  Json
  matchType                String // exact, likely, needs_review, no_match
  matchConfidence          Decimal   @db.Decimal(3, 2)
  candidateTenantId        String?
  candidateTenantName      String?
  candidateBuildingAddress String?
  candidateUnitNumber      String?
  sourceAddress            String?
  sourceUnit               String?
  sourceTenantName         String?
  sourceCaseNumber         String?
  status                   String    @default("pending") // pending, approved, rejected, auto_matched
  resolvedById             String?
  resolvedAt               DateTime?
  createdAt                DateTime  @default(now())

  @@index([importBatchId])
  @@index([status])
  @@map("legal_import_queue")
}

model LegalNote {
  id          String     @id @default(cuid())
  legalCaseId String
  authorId    String
  text        String     @db.Text
  stage       LegalStage
  isSystem    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  legalCase   LegalCase  @relation(fields: [legalCaseId], references: [id], onDelete: Restrict)
  author      User       @relation(fields: [authorId], references: [id])

  @@index([legalCaseId, createdAt(sort: Desc)])
  @@index([authorId])
  @@map("legal_notes")
}

model Task {
  id          String    @id @default(cuid())
  tenantId    String
  createdById String
  type        String
  description String
  dueDate     DateTime?
  done        Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdBy   User      @relation(fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([createdById])
  @@index([dueDate])
  @@map("tasks")
}

model VacancyInfo {
  id            String    @id @default(cuid())
  unitId        String    @unique
  condition     String?
  accessType    String?
  accessNotes   String?
  proposedRent  Decimal?  @db.Decimal(10, 2)
  readyDate     DateTime?
  internalNotes String?   @db.Text
  brokerNotes   Json?
  updatedAt     DateTime  @updatedAt
  unit          Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@map("vacancy_info")
}

model DhcrRent {
  id          String   @id @default(cuid())
  buildingId  String
  unitNumber  String
  legalRent   Decimal  @db.Decimal(10, 2)
  regId       String?
  dhcrAddress String?
  importedAt  DateTime @default(now())

  @@unique([buildingId, unitNumber])
  @@map("dhcr_rents")
}

model ImportBatch {
  id          String    @id @default(cuid())
  buildingId  String?
  filename    String
  format      String
  recordCount Int       @default(0)
  status      String    @default("completed")
  errors      Json?
  importedAt  DateTime  @default(now())
  building    Building? @relation(fields: [buildingId], references: [id])

  @@index([buildingId])
  @@map("import_batches")
}

enum EmailType {
  DEMAND_LETTER
  PAYMENT_REMINDER
  LATE_NOTICE
  COLLECTION_REPORT
  LEASE_RENEWAL
  CUSTOM
}

model EmailLog {
  id             String    @id @default(cuid())
  tenantId       String?
  sentById       String
  type           EmailType
  subject        String
  body           String    @db.Text
  recipientEmail String
  status         String    @default("sent")
  sentAt         DateTime  @default(now())
  tenant         Tenant?   @relation(fields: [tenantId], references: [id])
  sentBy         User      @relation(fields: [sentById], references: [id])

  @@index([tenantId, sentAt(sort: Desc)])
  @@index([sentById])
  @@map("email_logs")
}

// ── Work Order & Maintenance ──────────────────────────────────────

enum WorkOrderStatus {
  PENDING_REVIEW
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkOrderCategory {
  PLUMBING
  ELECTRICAL
  HVAC
  APPLIANCE
  GENERAL
  OTHER
}

enum MaintenanceFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

model Vendor {
  id                   String                     @id @default(cuid())
  name                 String
  company              String?
  email                String?
  phone                String?
  specialty            String?
  contactType          String                     @default("vendor") // vendor | broker | attorney | marshal
  hourlyRate           Decimal?                   @db.Decimal(10, 2)
  notes                String?                    @db.Text
  organizationId       String?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  workOrders           WorkOrder[]
  complianceItems      ComplianceItem[]
  vacanciesBrokered    Vacancy[]                  @relation("VacancyBroker")
  legalCasesAsAttorney LegalCase[]                @relation("LegalCaseAttorney")
  legalCasesAsMarshal  LegalCase[]                @relation("LegalCaseMarshal")
  violationsAssigned   Violation[]                @relation("ViolationVendor")
  turnoverAssignments  TurnoverVendorAssignment[]
  trades               VendorTrade[]
  buildingAssignments  VendorAssignment[]
  buildingVendors      BuildingVendor[]    @relation("BuildingVendorVendor")

  @@index([contactType])
  @@index([organizationId])
  @@map("vendors")
}

model WorkOrder {
  id              String              @id @default(cuid())
  title           String
  description     String              @db.Text
  status          WorkOrderStatus     @default(OPEN)
  priority        WorkOrderPriority   @default(MEDIUM)
  category        WorkOrderCategory   @default(GENERAL)
  photos          Json?
  estimatedCost   Decimal?            @db.Decimal(10, 2)
  actualCost      Decimal?            @db.Decimal(10, 2)
  scheduledDate   DateTime?
  completedDate   DateTime?
  buildingId      String
  unitId          String?
  tenantId        String?
  vendorId        String?
  assignedToId    String?
  createdById     String?
  sourceType      String? // manual | inspection | violation | vacancy | move_out
  sourceId        String?
  violationId     String?
  trade           String?
  dueDate         DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  building        Building            @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit            Unit?               @relation(fields: [unitId], references: [id])
  tenant          Tenant?             @relation(fields: [tenantId], references: [id])
  vendor          Vendor?             @relation(fields: [vendorId], references: [id])
  violationDirect Violation?          @relation("WorkOrderViolation", fields: [violationId], references: [id])
  assignedTo      User?               @relation("WorkOrderAssignee", fields: [assignedToId], references: [id])
  createdBy       User?               @relation("WorkOrderCreator", fields: [createdById], references: [id])
  comments        WorkOrderComment[]
  activities      WorkOrderActivity[]
  violations      Violation[]
  inspectionItems InspectionItem[]
  evidence        Evidence[]

  @@index([buildingId])
  @@index([unitId])
  @@index([tenantId])
  @@index([assignedToId])
