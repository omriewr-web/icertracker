// ── Operational Intelligence Engine ──────────────────────────────

model OperationalSignal {
  id                String    @id @default(cuid())
  deduplicationKey  String    @unique // e.g. "collections-risk-high-[tenantId]"
  type              String // collections_risk | legal_escalation | vacancy_risk | violation_risk | maintenance_failure | lease_expiration | utility_problem
  severity          String // low | medium | high | critical
  title             String
  description       String    @db.Text
  entityType        String // tenant | building | unit | workorder | violation | lease | meter | complaint
  entityId          String
  buildingId        String?
  tenantId          String?
  organizationId    String?
  status            String    @default("active") // active | acknowledged | resolved
  lastTriggeredAt   DateTime  @default(now())
  acknowledgedAt    DateTime?
  resolvedAt        DateTime?
  assignedToUserId  String?
  dueAt             DateTime?
  snoozedUntil      DateTime?
  recommendedAction String?   @db.Text
  resolutionNote    String?   @db.Text
  acknowledgedById  String?
  resolvedById      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  assignedToUser    User?     @relation("SignalAssignee", fields: [assignedToUserId], references: [id])
  acknowledgedBy    User?     @relation("SignalAcknowledger", fields: [acknowledgedById], references: [id])
  resolvedBy        User?     @relation("SignalResolver", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([severity])
  @@index([type])
  @@index([buildingId])
  @@index([tenantId])
  @@index([organizationId])
  @@index([assignedToUserId])
  @@index([dueAt])
  @@map("operational_signals")
}

model SignalScanLog {
  id              String    @id @default(cuid())
  scanType        String // manual | scheduled
  triggeredById   String?
  organizationId  String?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  durationMs      Int?
  success         Boolean   @default(true)
  errorMessage    String?   @db.Text
  createdSignals  Int       @default(0)
  updatedSignals  Int       @default(0)
  resolvedSignals Int       @default(0)
  triggeredBy     User?     @relation(fields: [triggeredById], references: [id])

  @@index([triggeredById])
  @@index([organizationId])
  @@index([startedAt])
  @@map("signal_scan_logs")
}

