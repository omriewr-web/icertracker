// AtlasPM - Database Schema
// Stack: PostgreSQL via Supabase + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  PM
  COLLECTOR
  OWNER
  BROKER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  username      String    @unique
  passwordHash  String
  role          UserRole  @default(COLLECTOR)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  assignedProperties UserProperty[]
  notes         TenantNote[]
  commLogs      CommLog[]
  payments      Payment[]
  legalNotes    LegalNote[]
  tasks         Task[]
  emails        EmailLog[]
  assignedWorkOrders    WorkOrder[] @relation("WorkOrderAssignee")
  createdWorkOrders     WorkOrder[] @relation("WorkOrderCreator")
  workOrderComments     WorkOrderComment[]
  assignedViolations    Violation[]
  assignedCollections   CollectionCase[] @relation("CollectionAssignee")
  assignedVacancies     Vacancy[]        @relation("VacancyAssignee")
  assignedLegalCases    LegalCase[]      @relation("LegalCaseAssignee")
  assignedInspections   Inspection[]     @relation("InspectionAssignee")
  assignedMoveOuts      MoveOutAssessment[] @relation("MoveOutAssignee")
  activityEvents        ActivityEvent[]
  @@map("users")
}

model UserProperty {
  id         String   @id @default(cuid())
  userId     String
  buildingId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  @@unique([userId, buildingId])
  @@map("user_properties")
}

model Building {
  id             String   @id @default(cuid())
  yardiId        String   @unique
  buildingName   String?
  address        String
  altAddress     String?
  city           String?  @default("New York")
  state          String?  @default("NY")
  borough        String?
  entity         String?
  portfolio      String?
  region         String?
  zip            String?
  block          String?
  lot            String?
  bbl            String?
  type           String   @default("Residential")
  owner          String?
  ownerEmail     String?
  manager        String?
  managementCompany String?
  arTeam         String?
  apTeam         String?
  headPortfolio  String?
  mgmtStartDate  DateTime?
  einNumber      String?

  // DOB / Registration IDs
  bin            String?  // BIN # (DOB)
  mdrNumber      String?  // MDR Number
  dhcrRegId      String?  // DHCR Registration ID
  hpdRegistrationId String?
  certificateOfOccupancy String?

  // Construction Details
  squareFootage  Int?
  yearBuilt      Int?
  constructionType String?
  floors         Int?
  floorsBelowGround Int?
  buildingClass  String?

  // Building Status & Designations
  buildingStatus String   @default("active")
  rentStabilized Boolean  @default(false)
  landmarkStatus String   @default("none")
  aepStatus      String   @default("none")

  // Mechanical Systems (scalar)
  boilerType     String?
  boilerInstallYear Int?
  hotWaterType   String?
  gasType        String?
  elevator       Boolean  @default(false)
  elevatorCount  Int      @default(0)
  sprinklerSystem Boolean @default(false)
  fireAlarmSystem Boolean @default(false)
  oilTank        Boolean  @default(false)

  // Life Safety Systems (JSON — legacy, still populated on import)
  lifeSafety     Json?
  // Elevator Info (JSON — legacy, still populated on import)
  elevatorInfo   Json?
  // Boiler Info (JSON — legacy, still populated on import)
  boilerInfo     Json?
  // Compliance Filing Dates (JSON)
  complianceDates Json?

  superintendent Json?
  elevatorCompany Json?
  fireAlarmCompany Json?
  utilityMeters  Json?
  utilityAccounts Json?
  totalUnits     Int      @default(0)
  commercialUnits Int     @default(0)
  lastInspectionDate DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  units          Unit[]
  assignedUsers  UserProperty[]
  importBatches  ImportBatch[]
  workOrders     WorkOrder[]
  maintenanceSchedules MaintenanceSchedule[]
  organizationId String?
  ownerId        String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  ownerRecord    Owner?        @relation(fields: [ownerId], references: [id])
  violations     Violation[]
  complianceItems ComplianceItem[]
  violationSyncLogs ViolationSyncLog[]
  legalCases        LegalCase[]
  collectionCases   CollectionCase[]
  vacancies         Vacancy[]
  inspections       Inspection[]
  inspectionItems   InspectionItem[]
  moveOutAssessments MoveOutAssessment[]
  moveOutCharges    MoveOutCharge[]
  activityEvents    ActivityEvent[]
  @@index([organizationId])
  @@index([ownerId])
  @@index([portfolio])
  @@index([region])
  @@index([borough])
  @@index([bbl])
  @@index([block, lot])
  @@index([buildingStatus])
  @@map("buildings")
}

model Unit {
  id          String   @id @default(cuid())
  buildingId  String
  unitNumber  String
  unitType    String?
  isVacant    Boolean  @default(false)
  building    Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  tenant      Tenant?
  vacancyInfo VacancyInfo?
  workOrders  WorkOrder[]
  maintenanceSchedules MaintenanceSchedule[]
  leases      Lease[]
  violations    Violation[]
  legalCases    LegalCase[]
  collectionCases   CollectionCase[]
  vacancies         Vacancy[]
  inspections       Inspection[]
  inspectionItems   InspectionItem[]
  moveOutAssessments MoveOutAssessment[]
  moveOutCharges    MoveOutCharge[]
  activityEvents    ActivityEvent[]
  @@unique([buildingId, unitNumber])
  @@map("units")
}

model Tenant {
  id              String   @id @default(cuid())
  unitId          String   @unique
  yardiResidentId String?  @unique
  name            String
  email           String?
  phone           String?
  marketRent      Decimal  @default(0) @db.Decimal(10, 2)
  legalRent       Decimal  @default(0) @db.Decimal(10, 2)
  dhcrLegalRent   Decimal  @default(0) @db.Decimal(10, 2)
  prefRent        Decimal  @default(0) @db.Decimal(10, 2)
  actualRent      Decimal  @default(0) @db.Decimal(10, 2)
  chargeCode      String?
  isStabilized    Boolean  @default(false)
  deposit         Decimal  @default(0) @db.Decimal(10, 2)
  moveInDate      DateTime?
  leaseExpiration DateTime?
  moveOutDate     DateTime?
  balance         Decimal  @default(0) @db.Decimal(10, 2)
  arrearsCategory String   @default("current")
  arrearsDays     Int      @default(0)
  monthsOwed      Decimal  @default(0) @db.Decimal(5, 1)
  leaseStatus     String   @default("active")
  collectionScore Int      @default(0)
  overrides       Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  unit            Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  notes           TenantNote[]
  commLogs        CommLog[]
  payments        Payment[]
  legalCase       LegalCase?
  tasks           Task[]
  emails          EmailLog[]
  workOrders      WorkOrder[]
  leases          Lease[]
  balanceSnapshots BalanceSnapshot[]
  collectionCases   CollectionCase[]
  moveOutAssessments MoveOutAssessment[]
  moveOutCharges    MoveOutCharge[]
  activityEvents    ActivityEvent[]
  @@index([balance])
  @@index([arrearsCategory])
  @@index([leaseExpiration])
  @@index([collectionScore])
  @@map("tenants")
}

enum NoteCategory {
  GENERAL
  COLLECTION
  PAYMENT
  LEGAL
  LEASE
  MAINTENANCE
}

model TenantNote {
  id        String       @id @default(cuid())
  tenantId  String
  authorId  String
  text      String       @db.Text
  category  NoteCategory @default(GENERAL)
  createdAt DateTime     @default(now())
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author    User         @relation(fields: [authorId], references: [id])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("tenant_notes")
}

enum CommType {
  PHONE
  EMAIL
  LETTER
  IN_PERSON
  TEXT_MSG
  LEGAL_NOTICE
  OTHER
}

model CommLog {
  id        String   @id @default(cuid())
  tenantId  String
  authorId  String
  type      CommType
  summary   String   @db.Text
  outcome   String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("comm_logs")
}

model Payment {
  id          String   @id @default(cuid())
  tenantId    String
  recordedBy  String
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime
  method      String?
  reference   String?
  notes       String?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recorder    User     @relation(fields: [recordedBy], references: [id])
  @@index([tenantId, date(sort: Desc)])
  @@map("payments")
}

enum LegalStage {
  NOTICE_SENT
  HOLDOVER
  NONPAYMENT
  COURT_DATE
  STIPULATION
  JUDGMENT
  WARRANT
  EVICTION
  SETTLED
}

model LegalCase {
  id               String     @id @default(cuid())
  tenantId         String     @unique
  buildingId       String?
  unitId           String?
  collectionCaseId String?
  attorneyId       String?
  assignedUserId   String?
  inLegal          Boolean    @default(true)
  stage            LegalStage @default(NOTICE_SENT)
  caseNumber       String?
  attorney         String?
  filedDate        DateTime?
  courtDate        DateTime?
  arrearsBalance   Decimal?   @db.Decimal(10, 2)
  status           String     @default("active")  // active, settled, dismissed, withdrawn
  importBatchId    String?
  isActive         Boolean    @default(true)
  notes_text       String?    @db.Text
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building         Building?       @relation(fields: [buildingId], references: [id])
  unit             Unit?           @relation(fields: [unitId], references: [id])
  collectionCase   CollectionCase? @relation(fields: [collectionCaseId], references: [id])
  attorneyContact  Vendor?         @relation("LegalCaseAttorney", fields: [attorneyId], references: [id])
  assignedUser     User?           @relation("LegalCaseAssignee", fields: [assignedUserId], references: [id])
  notes            LegalNote[]
  @@index([stage])
  @@index([status])
  @@index([buildingId])
  @@index([collectionCaseId])
  @@map("legal_cases")
}

model LegalImportQueue {
  id              String   @id @default(cuid())
  importBatchId   String
  rowIndex        Int
  rawData         Json
  matchType       String   // exact, likely, needs_review, no_match
  matchConfidence Decimal  @db.Decimal(3, 2)
  candidateTenantId String?
  candidateTenantName String?
  candidateBuildingAddress String?
  candidateUnitNumber String?
  sourceAddress   String?
  sourceUnit      String?
  sourceTenantName String?
  sourceCaseNumber String?
  status          String   @default("pending")  // pending, approved, rejected, auto_matched
  resolvedById    String?
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  @@index([importBatchId])
  @@index([status])
  @@map("legal_import_queue")
}

model LegalNote {
  id          String     @id @default(cuid())
  legalCaseId String
  authorId    String
  text        String     @db.Text
  stage       LegalStage
  createdAt   DateTime   @default(now())
  legalCase   LegalCase  @relation(fields: [legalCaseId], references: [id], onDelete: Cascade)
  author      User       @relation(fields: [authorId], references: [id])
  @@index([legalCaseId, createdAt(sort: Desc)])
  @@map("legal_notes")
}

model Task {
  id          String   @id @default(cuid())
  tenantId    String
  createdById String
  type        String
  description String
  dueDate     DateTime?
  done        Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id])
  @@index([tenantId])
  @@index([dueDate])
  @@map("tasks")
}

model VacancyInfo {
  id           String   @id @default(cuid())
  unitId       String   @unique
  condition    String?
  accessType   String?
  accessNotes  String?
  proposedRent Decimal? @db.Decimal(10, 2)
  readyDate    DateTime?
  internalNotes String?  @db.Text
  brokerNotes  Json?
  updatedAt    DateTime @updatedAt
  unit         Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  @@map("vacancy_info")
}

model DhcrRent {
  id           String   @id @default(cuid())
  buildingId   String
  unitNumber   String
  legalRent    Decimal  @db.Decimal(10, 2)
  regId        String?
  dhcrAddress  String?
  importedAt   DateTime @default(now())
  @@unique([buildingId, unitNumber])
  @@map("dhcr_rents")
}

model ImportBatch {
  id          String   @id @default(cuid())
  buildingId  String?
  filename    String
  format      String
  recordCount Int      @default(0)
  status      String   @default("completed")
  errors      Json?
  importedAt  DateTime @default(now())
  building    Building? @relation(fields: [buildingId], references: [id])
  @@map("import_batches")
}

enum EmailType {
  DEMAND_LETTER
  PAYMENT_REMINDER
  LATE_NOTICE
  COLLECTION_REPORT
  LEASE_RENEWAL
  CUSTOM
}

model EmailLog {
  id             String    @id @default(cuid())
  tenantId       String?
  sentById       String
  type           EmailType
  subject        String
  body           String    @db.Text
  recipientEmail String
  status         String    @default("sent")
  sentAt         DateTime  @default(now())
  tenant         Tenant?   @relation(fields: [tenantId], references: [id])
  sentBy         User      @relation(fields: [sentById], references: [id])
  @@index([tenantId, sentAt(sort: Desc)])
  @@map("email_logs")
}

// ── Work Order & Maintenance ──────────────────────────────────────

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkOrderCategory {
  PLUMBING
  ELECTRICAL
  HVAC
  APPLIANCE
  GENERAL
  OTHER
}

enum MaintenanceFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

model Vendor {
  id          String   @id @default(cuid())
  name        String
  company     String?
  email       String?
  phone       String?
  specialty   String?
  contactType String   @default("vendor")  // vendor | broker | attorney
  hourlyRate  Decimal? @db.Decimal(10, 2)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workOrders  WorkOrder[]
  complianceItems ComplianceItem[]
  vacanciesBrokered Vacancy[]   @relation("VacancyBroker")
  legalCasesAsAttorney LegalCase[] @relation("LegalCaseAttorney")
  violationsAssigned   Violation[] @relation("ViolationVendor")
  @@index([contactType])
  @@map("vendors")
}

model WorkOrder {
  id             String            @id @default(cuid())
  title          String
  description    String            @db.Text
  status         WorkOrderStatus   @default(OPEN)
  priority       WorkOrderPriority @default(MEDIUM)
  category       WorkOrderCategory @default(GENERAL)
  photos         Json?
  estimatedCost  Decimal?          @db.Decimal(10, 2)
  actualCost     Decimal?          @db.Decimal(10, 2)
  scheduledDate  DateTime?
  completedDate  DateTime?
  buildingId     String
  unitId         String?
  tenantId       String?
  vendorId       String?
  assignedToId   String?
  createdById    String?
  sourceType     String?           // manual | inspection | violation | vacancy | move_out
  sourceId       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  building       Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit           Unit?             @relation(fields: [unitId], references: [id])
  tenant         Tenant?           @relation(fields: [tenantId], references: [id])
  vendor         Vendor?           @relation(fields: [vendorId], references: [id])
  assignedTo     User?             @relation("WorkOrderAssignee", fields: [assignedToId], references: [id])
  createdBy      User?             @relation("WorkOrderCreator", fields: [createdById], references: [id])
  comments       WorkOrderComment[]
  violations     Violation[]
  inspectionItems InspectionItem[]
  @@index([buildingId])
  @@index([status])
  @@index([priority])
  @@index([sourceType, sourceId])
  @@map("work_orders")
}

model WorkOrderComment {
  id          String    @id @default(cuid())
  workOrderId String
  authorId    String
  text        String    @db.Text
  photos      Json?
  createdAt   DateTime  @default(now())
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id])
  @@index([workOrderId, createdAt(sort: Desc)])
  @@map("work_order_comments")
}

model MaintenanceSchedule {
  id                 String               @id @default(cuid())
  title              String
  description        String?              @db.Text
  frequency          MaintenanceFrequency
  nextDueDate        DateTime
  autoCreateWorkOrder Boolean             @default(true)
  buildingId         String
  unitId             String?
  building           Building             @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit               Unit?                @relation(fields: [unitId], references: [id])
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  @@index([nextDueDate])
  @@map("maintenance_schedules")
}

// ── Compliance & Violations ─────────────────────────────────────

enum ViolationSource {
  HPD
  DOB
  ECB
  FDNY
  DSNY
  DOHMH
  DOB_COMPLAINTS
  HPD_COMPLAINTS
  HPD_LITIGATION
}

enum ViolationClass {
  A
  B
  C
  I
  CLASS1
  CLASS2
  CLASS3
}

enum ViolationSeverity {
  IMMEDIATELY_HAZARDOUS
  HAZARDOUS
  NON_HAZARDOUS
  INFO
}

enum ComplianceCategory {
  LOCAL_LAW
  INSPECTION
  FILING
  CUSTOM
}

enum ComplianceFrequency {
  ANNUAL
  SEMI_ANNUAL
  QUARTERLY
  FIVE_YEAR
  FOUR_YEAR
  ONE_TIME
  ON_EVENT
}

enum ComplianceStatus {
  COMPLIANT
  NON_COMPLIANT
  PENDING
  OVERDUE
  SCHEDULED
  NOT_APPLICABLE
}

model Violation {
  id                  String            @id @default(cuid())
  buildingId          String
  unitId              String?
  assignedUserId      String?
  assignedVendorId    String?
  source              ViolationSource
  externalId          String
  class               ViolationClass?
  severity            ViolationSeverity?
  description         String            @db.Text
  inspectionDate      DateTime?
  issuedDate          DateTime?
  currentStatus       String?
  penaltyAmount       Decimal           @default(0) @db.Decimal(10, 2)
  respondByDate       DateTime?
  certifiedDismissDate DateTime?
  correctionDate      DateTime?
  targetCompletionDate DateTime?
  certificationDate   DateTime?
  remediationNotes    String?           @db.Text
  isOpen              Boolean           @default(true)
  unitNumber          String?
  novDescription      String?           @db.Text
  hearingDate         DateTime?
  hearingStatus       String?
  linkedWorkOrderId   String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  building            Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit                Unit?             @relation(fields: [unitId], references: [id])
  assignedUser        User?             @relation(fields: [assignedUserId], references: [id])
  assignedVendor      Vendor?           @relation("ViolationVendor", fields: [assignedVendorId], references: [id])
  linkedWorkOrder     WorkOrder?        @relation(fields: [linkedWorkOrderId], references: [id])
  complianceItems     ComplianceItem[]
  @@unique([source, externalId])
  @@index([buildingId])
  @@index([unitId])
  @@index([source])
  @@index([currentStatus])
  @@index([isOpen])
  @@index([hearingDate])
  @@index([respondByDate])
  @@map("violations")
}

model ComplianceItem {
  id                String             @id @default(cuid())
  buildingId        String
  type              String
  category          ComplianceCategory
  name              String
  description       String             @db.Text
  dueDate           DateTime?
  frequency         ComplianceFrequency
  status            ComplianceStatus   @default(PENDING)
  lastCompletedDate DateTime?
  nextDueDate       DateTime?
  assignedVendorId  String?
  cost              Decimal            @default(0) @db.Decimal(10, 2)
  filedBy           String?
  certificateUrl    String?
  notes             String?            @db.Text
  linkedViolationId String?
  isCustom          Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  building          Building           @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  assignedVendor    Vendor?            @relation(fields: [assignedVendorId], references: [id])
  linkedViolation   Violation?         @relation(fields: [linkedViolationId], references: [id])
  @@index([buildingId])
  @@index([status])
  @@index([nextDueDate])
  @@index([category])
  @@map("compliance_items")
}

model ViolationSyncLog {
  id           String   @id @default(cuid())
  buildingId   String?
  source       ViolationSource
  syncedAt     DateTime @default(now())
  newCount     Int      @default(0)
  updatedCount Int      @default(0)
  status       String   @default("completed")
  building     Building? @relation(fields: [buildingId], references: [id])
  @@index([buildingId, syncedAt(sort: Desc)])
  @@map("violation_sync_logs")
}

// ── Phase 1: Normalized Domain Models ──────────────────────────────

enum LeaseStatus {
  ACTIVE
  EXPIRED
  MONTH_TO_MONTH
  RENEWED
  TERMINATED
  PENDING
}

enum OccupancyStatus {
  OCCUPIED
  VACANT
  NOTICE_GIVEN
  EVICTION_IN_PROGRESS
}

enum OccupantRole {
  PRIMARY
  SPOUSE
  DEPENDENT
  ROOMMATE
  GUARANTOR
  AUTHORIZED_REP
}

enum PaymentFrequency {
  MONTHLY
  WEEKLY
  BIWEEKLY
}

enum BillingStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum ImportType {
  RENT_ROLL
  AGING
  BUILDING
  DHCR
  TENANT_MASTER
}

enum ImportRowStatus {
  MATCHED
  CREATED
  UPDATED
  SKIPPED
  ERROR
}

model Lease {
  id                String          @id @default(cuid())
  unitId            String
  tenantId          String?
  leaseStart        DateTime?
  leaseEnd          DateTime?
  monthlyRent       Decimal         @default(0) @db.Decimal(10, 2)
  legalRent         Decimal         @default(0) @db.Decimal(10, 2)
  preferentialRent  Decimal         @default(0) @db.Decimal(10, 2)
  subsidyType       String?
  subsidyAmount     Decimal         @default(0) @db.Decimal(10, 2)
  tenantPortion     Decimal         @default(0) @db.Decimal(10, 2)
  renewalStatus     String?
  leaseType         String?
  status            LeaseStatus     @default(ACTIVE)
  paymentFrequency  PaymentFrequency @default(MONTHLY)
  billingStatus     BillingStatus   @default(ACTIVE)
  isStabilized      Boolean         @default(false)
  householdSize     Int?
  securityDeposit   Decimal         @default(0) @db.Decimal(10, 2)
  notes             String?         @db.Text
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  unit              Unit            @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant            Tenant?         @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  occupants         LeaseOccupant[]
  recurringCharges  RecurringCharge[]
  balanceSnapshots  BalanceSnapshot[]
  @@index([unitId])
  @@index([tenantId])
  @@index([status])
  @@index([leaseEnd])
  @@map("leases")
}

model LeaseOccupant {
  id        String       @id @default(cuid())
  leaseId   String
  name      String
  role      OccupantRole @default(PRIMARY)
  isPrimary Boolean      @default(false)
  phone     String?
  email     String?
  createdAt DateTime     @default(now())
  lease     Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  @@index([leaseId])
  @@map("lease_occupants")
}

model RecurringCharge {
  id          String   @id @default(cuid())
  leaseId     String
  chargeCode  String
  description String?
  amount      Decimal  @db.Decimal(10, 2)
  frequency   PaymentFrequency @default(MONTHLY)
  startDate   DateTime?
  endDate     DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lease       Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  @@index([leaseId])
  @@index([active])
  @@map("recurring_charges")
}

model BalanceSnapshot {
  id                String   @id @default(cuid())
  tenantId          String?
  leaseId           String?
  importBatchId     String?
  snapshotDate      DateTime @default(now())
  currentCharges    Decimal  @default(0) @db.Decimal(10, 2)
  currentBalance    Decimal  @default(0) @db.Decimal(10, 2)
  pastDueBalance    Decimal  @default(0) @db.Decimal(10, 2)
  lastPaymentDate   DateTime?
  lastPaymentAmount Decimal? @db.Decimal(10, 2)
  arrearsStatus     String   @default("current")
  createdAt         DateTime @default(now())
  tenant            Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  lease             Lease?   @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  @@index([tenantId, snapshotDate(sort: Desc)])
  @@index([leaseId])
  @@index([snapshotDate])
  @@map("balance_snapshots")
}

model ImportRow {
  id            String         @id @default(cuid())
  importBatchId String
  rowIndex      Int
  rawData       Json
  status        ImportRowStatus @default(MATCHED)
  entityType    String?
  entityId      String?
  errors        Json?
  createdAt     DateTime       @default(now())
  @@index([importBatchId])
  @@index([status])
  @@map("import_rows")
}

// ── Self-Learning Import Profiles ────────────────────────────────

model ImportProfile {
  id               String   @id @default(cuid())
  organizationId   String   @default("default")
  name             String
  importType       String
  sheetNamePattern String?
  headerRowCount   Int
  fingerprintJson  Json
  mappingJson      Json
  ignoredRulesJson Json?
  isActive         Boolean  @default(true)
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  runs             ImportRun[]
  feedback         ImportFeedback[]
  @@index([organizationId, importType])
  @@map("import_profiles")
}

model ImportRun {
  id               String   @id @default(cuid())
  organizationId   String   @default("default")
  fileName         String
  importType       String
  matchedProfileId String?
  aiUsed           Boolean  @default(false)
  status           String   @default("pending")
  analysisJson     Json
  finalMappingJson Json?
  createdById      String?
  createdAt        DateTime @default(now())
  matchedProfile   ImportProfile? @relation(fields: [matchedProfileId], references: [id])
  feedback         ImportFeedback[]
  @@index([organizationId, importType])
  @@index([matchedProfileId])
  @@map("import_runs")
}

model ImportFeedback {
  id                 String   @id @default(cuid())
  importRunId        String
  importProfileId    String?
  fieldName          String
  originalSuggestion String?
  finalUserChoice    String?
  corrected          Boolean  @default(false)
  createdAt          DateTime @default(now())
  importRun          ImportRun     @relation(fields: [importRunId], references: [id], onDelete: Cascade)
  importProfile      ImportProfile? @relation(fields: [importProfileId], references: [id])
  @@index([importRunId])
  @@index([importProfileId])
  @@map("import_feedback")
}

// ── Core Entity Models ──────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  buildings Building[]
  activityEvents ActivityEvent[]
  @@map("organizations")
}

model Owner {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  buildings Building[]
  @@map("owners")
}

// ── Operational Records ─────────────────────────────────────────

model CollectionCase {
  id              String   @id @default(cuid())
  buildingId      String
  unitId          String
  tenantId        String
  assignedUserId  String?
  balanceOwed     Decimal  @default(0) @db.Decimal(10, 2)
  daysLate        Int      @default(0)
  status          String   @default("new_arrears") // new_arrears | reminder_sent | payment_plan | notice_served | legal_review | legal_filed
  lastActionDate  DateTime?
  nextActionDate  DateTime?
  notes           String?  @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  building        Building @relation(fields: [buildingId], references: [id])
  unit            Unit     @relation(fields: [unitId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  assignedUser    User?    @relation("CollectionAssignee", fields: [assignedUserId], references: [id])
  legalCases      LegalCase[]
  @@index([buildingId])
  @@index([tenantId])
  @@index([status])
  @@index([isActive])
  @@map("collection_cases")
}

model Vacancy {
  id              String   @id @default(cuid())
  buildingId      String
  unitId          String
  brokerId        String?
  assignedUserId  String?
  stage           String   @default("vacant") // vacant | renovation | listed | showing | application | lease_signed
  askingRent      Decimal? @db.Decimal(10, 2)
  showingsCount   Int      @default(0)
  listedDate      DateTime?
  applicationDate DateTime?
  leaseSignedDate DateTime?
  moveInDate      DateTime?
  notes           String?  @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  building        Building @relation(fields: [buildingId], references: [id])
  unit            Unit     @relation(fields: [unitId], references: [id])
  broker          Vendor?  @relation("VacancyBroker", fields: [brokerId], references: [id])
  assignedUser    User?    @relation("VacancyAssignee", fields: [assignedUserId], references: [id])
  @@index([buildingId])
  @@index([unitId])
  @@index([isActive])
  @@index([stage])
  @@map("vacancies")
}

model Inspection {
  id              String   @id @default(cuid())
  buildingId      String
  unitId          String?
  assignedUserId  String?
  inspectionType  String
  frequencyType   String   @default("one_time") // monthly | weekly | move_in | move_out | one_time
  scheduledFor    DateTime?
  completedAt     DateTime?
  overallStatus   String   @default("pending") // pending | in_progress | completed | cancelled
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  building        Building   @relation(fields: [buildingId], references: [id])
  unit            Unit?      @relation(fields: [unitId], references: [id])
  assignedUser    User?      @relation("InspectionAssignee", fields: [assignedUserId], references: [id])
  items           InspectionItem[]
  moveOutAssessments MoveOutAssessment[]
  @@index([buildingId])
  @@index([scheduledFor])
  @@index([overallStatus])
  @@map("inspections")
}

model InspectionItem {
  id                    String   @id @default(cuid())
  inspectionId          String
  buildingId            String
  unitId                String?
  label                 String
  status                String   @default("pending") // pass | fail | needs_attention | na | pending
  notes                 String?  @db.Text
  generatedWorkOrderId  String?
  createdAt             DateTime @default(now())
  inspection            Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  building              Building   @relation(fields: [buildingId], references: [id])
  unit                  Unit?      @relation(fields: [unitId], references: [id])
  generatedWorkOrder    WorkOrder? @relation(fields: [generatedWorkOrderId], references: [id])
  @@index([inspectionId])
  @@map("inspection_items")
}

model MoveOutAssessment {
  id                        String   @id @default(cuid())
  buildingId                String
  unitId                    String
  tenantId                  String
  inspectionId              String?
  assignedUserId            String?
  securityDepositAmount     Decimal  @default(0) @db.Decimal(10, 2)
  recommendedChargesTotal   Decimal  @default(0) @db.Decimal(10, 2)
  recommendedDepositReturn  Decimal  @default(0) @db.Decimal(10, 2)
  recommendationStatus      String   @default("draft") // draft | reviewed | approved | sent
  draftEmailBody            String?  @db.Text
  completedAt               DateTime?
  notes                     String?  @db.Text
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  building                  Building    @relation(fields: [buildingId], references: [id])
  unit                      Unit        @relation(fields: [unitId], references: [id])
  tenant                    Tenant      @relation(fields: [tenantId], references: [id])
  inspection                Inspection? @relation(fields: [inspectionId], references: [id])
  assignedUser              User?       @relation("MoveOutAssignee", fields: [assignedUserId], references: [id])
  charges                   MoveOutCharge[]
  @@index([buildingId])
  @@index([tenantId])
  @@map("move_out_assessments")
}

model MoveOutCharge {
  id                  String   @id @default(cuid())
  moveOutAssessmentId String
  buildingId          String
  unitId              String
  tenantId            String
  chargeCode          String
  chargeLabel         String
  quantity            Int      @default(1)
  unitPrice           Decimal  @db.Decimal(10, 2)
  totalPrice          Decimal  @db.Decimal(10, 2)
  notes               String?  @db.Text
  createdAt           DateTime @default(now())
  assessment          MoveOutAssessment @relation(fields: [moveOutAssessmentId], references: [id], onDelete: Cascade)
  building            Building @relation(fields: [buildingId], references: [id])
  unit                Unit     @relation(fields: [unitId], references: [id])
  tenant              Tenant   @relation(fields: [tenantId], references: [id])
  @@index([moveOutAssessmentId])
  @@map("move_out_charges")
}

// ── Import Staging ─────────────────────────────────────────────

model ImportStagingBatch {
  id              String   @id @default(cuid())
  importType      String   @default("tenant_list") // tenant_list | rent_roll | aging | building
  fileName        String
  uploadedById    String
  status          String   @default("pending_review") // pending_review | approved | rejected | expired
  rowsJson        Json     // Array of parsed row objects
  mappingJson     Json     // Column mapping used
  summaryJson     Json     // { total, newTenants, updates, errors, buildings }
  reviewedById    String?
  reviewedAt      DateTime?
  reviewNotes     String?  @db.Text
  importBatchId   String?  // set after approval creates the real ImportBatch
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([status])
  @@index([uploadedById])
  @@map("import_staging_batches")
}

// ── Shared Activity Timeline ────────────────────────────────────

model ActivityEvent {
  id                String   @id @default(cuid())
  eventType         String   // legal_case_created | work_order_completed | payment_received | vacancy_listed | inspection_completed | collection_escalated | ...
  title             String
  description       String?  @db.Text
  organizationId    String?
  buildingId        String?
  unitId            String?
  tenantId          String?
  relatedRecordType String?  // LegalCase | WorkOrder | CollectionCase | Vacancy | Inspection | MoveOutAssessment | ...
  relatedRecordId   String?
  createdByUserId   String?
  eventTimestamp    DateTime @default(now())
  metadata          Json?
  createdAt         DateTime @default(now())
  organization      Organization? @relation(fields: [organizationId], references: [id])
  building          Building?     @relation(fields: [buildingId], references: [id])
  unit              Unit?         @relation(fields: [unitId], references: [id])
  tenant            Tenant?       @relation(fields: [tenantId], references: [id])
  createdByUser     User?         @relation(fields: [createdByUserId], references: [id])
  @@index([buildingId, eventTimestamp(sort: Desc)])
  @@index([unitId, eventTimestamp(sort: Desc)])
  @@index([tenantId, eventTimestamp(sort: Desc)])
  @@index([organizationId, eventTimestamp(sort: Desc)])
  @@index([relatedRecordType, relatedRecordId])
  @@index([eventType])
  @@map("activity_events")
}