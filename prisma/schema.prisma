// AtlasPM - Database Schema
// Stack: PostgreSQL via Supabase + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  ACCOUNT_ADMIN
  PM
  APM
  COLLECTOR
  OWNER
  LEASING_SPECIALIST
  BROKER
  SUPER
  ACCOUNTING
  LEASING_AGENT
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  name                String
  username            String              @unique
  passwordHash        String
  role                UserRole            @default(COLLECTOR)
  active              Boolean             @default(true)
  organizationId      String?
  managerId           String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  organization        Organization?       @relation(fields: [organizationId], references: [id])
  manager             User?               @relation("UserManager", fields: [managerId], references: [id])
  subordinates        User[]              @relation("UserManager")
  assignedProperties  UserProperty[]
  notes               TenantNote[]
  commLogs            CommLog[]
  payments            Payment[]
  legalNotes          LegalNote[]
  tasks               Task[]
  emails              EmailLog[]
  assignedWorkOrders  WorkOrder[]         @relation("WorkOrderAssignee")
  createdWorkOrders   WorkOrder[]         @relation("WorkOrderCreator")
  workOrderComments   WorkOrderComment[]
  assignedViolations  Violation[]
  assignedCollections CollectionCase[]    @relation("CollectionAssignee")
  assignedVacancies   Vacancy[]           @relation("VacancyAssignee")
  assignedLegalCases  LegalCase[]         @relation("LegalCaseAssignee")
  assignedInspections Inspection[]        @relation("InspectionAssignee")
  assignedMoveOuts    MoveOutAssessment[] @relation("MoveOutAssignee")
  activityEvents      ActivityEvent[]
  collectionNotes     CollectionNote[]
  assignedSignals     OperationalSignal[] @relation("SignalAssignee")
  acknowledgedSignals OperationalSignal[] @relation("SignalAcknowledger")
  resolvedSignals     OperationalSignal[] @relation("SignalResolver")
  scanLogs            SignalScanLog[]
  assignedTurnovers   TurnoverWorkflow[]  @relation("TurnoverAssignee")
  workOrderActivities WorkOrderActivity[] @relation("WorkOrderActivityUser")
  leasingActivities       LeasingActivity[]
  preparedCertPackets     CertificationPacket[] @relation("CertPacketPreparer")
  reviewedCertPackets     CertificationPacket[] @relation("CertPacketReviewer")
  pmVerifiedViolations    Violation[]           @relation("ViolationPMVerifier")
  prometheusIntakes       PrometheusIntake[]    @relation("PrometheusCreator")
  verifiedDrafts          WorkOrderDraft[]      @relation("DraftVerifier")

  @@index([organizationId])
  @@index([managerId])
  @@map("users")
}

model UserProperty {
  id         String   @id @default(cuid())
  userId     String
  buildingId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([userId, buildingId])
  @@map("user_properties")
}

model Building {
  id                String    @id @default(cuid())
  yardiId           String    @unique
  yardiCode         String?   @unique
  propertyId        String?   @unique
  buildingName      String?
  address           String
  altAddress        String?
  city              String?   @default("New York")
  state             String?   @default("NY")
  borough           String?
  entity            String?
  portfolio         String?
  region            String?
  zip               String?
  block             String?
  lot               String?
  bbl               String?
  type              String    @default("Residential")
  owner             String?
  ownerEmail        String?
  manager           String?
  managementCompany String?
  arTeam            String?
  apTeam            String?
  headPortfolio     String?
  mgmtStartDate     DateTime?
  einNumber         String?

  // DOB / Registration IDs
  bin                    String? // BIN # (DOB)
  mdrNumber              String? // MDR Number
  dhcrRegId              String? // DHCR Registration ID
  hpdRegistrationId      String?
  certificateOfOccupancy String?

  // Construction Details
  squareFootage     Int?
  yearBuilt         Int?
  constructionType  String?
  floors            Int?
  floorsBelowGround Int?
  buildingClass     String?

  // Building Status & Designations
  buildingStatus String  @default("active")
  rentStabilized Boolean @default(false)
  landmarkStatus String  @default("none")
  aepStatus      String  @default("none")

  // Mechanical Systems (scalar)
  boilerType        String?
  boilerInstallYear Int?
  hotWaterType      String?
  gasType           String?
  elevator          Boolean @default(false)
  elevatorCount     Int     @default(0)
  sprinklerSystem   Boolean @default(false)
  fireAlarmSystem   Boolean @default(false)
  oilTank           Boolean @default(false)

  // Life Safety Systems (JSON — legacy, still populated on import)
  lifeSafety      Json?
  // Elevator Info (JSON — legacy, still populated on import)
  elevatorInfo    Json?
  // Boiler Info (JSON — legacy, still populated on import)
  boilerInfo      Json?
  // Compliance Filing Dates (JSON)
  complianceDates Json?

  superintendent       Json?
  elevatorCompany      Json?
  fireAlarmCompany     Json?
  utilityMeters        Json?
  utilityAccounts      Json?
  totalUnits           Int                   @default(0)
  commercialUnits      Int                   @default(0)
  lastInspectionDate   DateTime?
  notes                String?
  publicAccessToken    String?               @unique
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  units                Unit[]
  assignedUsers        UserProperty[]
  importBatches        ImportBatch[]
  workOrders           WorkOrder[]
  maintenanceSchedules MaintenanceSchedule[]
  organizationId       String?
  ownerId              String?
  organization         Organization?         @relation(fields: [organizationId], references: [id])
  ownerRecord          Owner?                @relation(fields: [ownerId], references: [id])
  violations           Violation[]
  complianceItems      ComplianceItem[]
  violationSyncLogs    ViolationSyncLog[]
  legalCases           LegalCase[]
  collectionCases      CollectionCase[]
  vacancies            Vacancy[]
  inspections          Inspection[]
  inspectionItems      InspectionItem[]
  moveOutAssessments   MoveOutAssessment[]
  moveOutCharges       MoveOutCharge[]
  activityEvents       ActivityEvent[]
  complaints           Complaint[]
  collectionNotes      CollectionNote[]
  arSnapshots          ARSnapshot[]
  utilityMeterRecords  UtilityMeter[]
  turnoverWorkflows    TurnoverWorkflow[]
  leasingActivities    LeasingActivity[]
  riskScore            Float?
  riskCategory         String?
  lat                  Float?
  lng                  Float?

  leases                 Lease[]
  vendorAssignments      VendorAssignment[]
  riskSnapshots          RiskSnapshot[]
  certificationPackets   CertificationPacket[]
  prometheusIntakes      PrometheusIntake[]
  workOrderDrafts        WorkOrderDraft[]

  @@index([organizationId])
  @@index([ownerId])
  @@index([portfolio])
  @@index([region])
  @@index([borough])
  @@index([bbl])
  @@index([block, lot])
  @@index([buildingStatus])
  @@map("buildings")
}

model Unit {
  id                   String                @id @default(cuid())
  buildingId           String
  unitNumber           String
  unitType             String?
  unitCategory         String? // "residential", "commercial", "parking", "laundry", "super", "other"
  askingRent           Decimal?              @db.Decimal(10, 2)
  isVacant             Boolean               @default(false)
  isResidential        Boolean               @default(true)
  building             Building              @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  tenant               Tenant?
  vacancyInfo          VacancyInfo?
  workOrders           WorkOrder[]
  maintenanceSchedules MaintenanceSchedule[]
  leases               Lease[]
  violations           Violation[]
  legalCases           LegalCase[]
  collectionCases      CollectionCase[]
  vacancies            Vacancy[]
  inspections          Inspection[]
  inspectionItems      InspectionItem[]
  moveOutAssessments   MoveOutAssessment[]
  moveOutCharges       MoveOutCharge[]
  activityEvents       ActivityEvent[]
  complaints           Complaint[]
  utilityMeterRecords  UtilityMeter[]
  turnoverWorkflows    TurnoverWorkflow[]
  leasingActivities    LeasingActivity[]

  @@unique([buildingId, unitNumber])
  @@map("units")
}

model Tenant {
  id                 String              @id @default(cuid())
  unitId             String              @unique
  yardiResidentId    String?             @unique
  name               String
  email              String?
  phone              String?
  marketRent         Decimal             @default(0) @db.Decimal(10, 2)
  legalRent          Decimal             @default(0) @db.Decimal(10, 2)
  dhcrLegalRent      Decimal             @default(0) @db.Decimal(10, 2)
  prefRent           Decimal             @default(0) @db.Decimal(10, 2)
  actualRent         Decimal             @default(0) @db.Decimal(10, 2)
  chargeCode         String?
  isStabilized       Boolean             @default(false)
  deposit            Decimal             @default(0) @db.Decimal(10, 2)
  moveInDate         DateTime?
  leaseExpiration    DateTime?
  moveOutDate        DateTime?
  balance            Decimal             @default(0) @db.Decimal(10, 2)
  arrearsCategory    String              @default("current")
  arrearsDays        Int                 @default(0)
  monthsOwed         Decimal             @default(0) @db.Decimal(5, 1)
  leaseStatus        String              @default("active")
  collectionScore    Int                 @default(0)
  overrides          Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  unit               Unit                @relation(fields: [unitId], references: [id], onDelete: Cascade)
  notes              TenantNote[]
  commLogs           CommLog[]
  payments           Payment[]
  legalCases         LegalCase[]
  tasks              Task[]
  emails             EmailLog[]
  workOrders         WorkOrder[]
  leases             Lease[]
  balanceSnapshots   BalanceSnapshot[]
  collectionCases    CollectionCase[]
  moveOutAssessments MoveOutAssessment[]
  moveOutCharges     MoveOutCharge[]
  activityEvents     ActivityEvent[]
  collectionNotes    CollectionNote[]
  arSnapshots        ARSnapshot[]
  utilityAccounts    UtilityAccount[]
  paymentPlans       PaymentPlan[]

  @@index([balance])
  @@index([arrearsCategory])
  @@index([leaseExpiration])
  @@index([collectionScore])
  @@index([unitId, balance])
  @@map("tenants")
}

enum NoteCategory {
  GENERAL
  COLLECTION
  PAYMENT
  LEGAL
  LEASE
  MAINTENANCE
}

model TenantNote {
  id        String       @id @default(cuid())
  tenantId  String
  authorId  String
  text      String       @db.Text
  category  NoteCategory @default(GENERAL)
  createdAt DateTime     @default(now())
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author    User         @relation(fields: [authorId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([authorId])
  @@map("tenant_notes")
}

enum CommType {
  PHONE
  EMAIL
  LETTER
  IN_PERSON
  TEXT_MSG
  LEGAL_NOTICE
  OTHER
}

model CommLog {
  id        String   @id @default(cuid())
  tenantId  String
  authorId  String
  type      CommType
  summary   String   @db.Text
  outcome   String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([authorId])
  @@map("comm_logs")
}

model Payment {
  id         String   @id @default(cuid())
  tenantId   String
  recordedBy String
  amount     Decimal  @db.Decimal(10, 2)
  date       DateTime
  method     String?
  reference  String?
  notes      String?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recorder   User     @relation(fields: [recordedBy], references: [id])

  @@index([tenantId, date(sort: Desc)])
  @@index([recordedBy])
  @@map("payments")
}

enum LegalStage {
  NOTICE_SENT
  HOLDOVER
  NONPAYMENT
  COURT_DATE
  STIPULATION
  JUDGMENT
  WARRANT
  EVICTION
  SETTLED
}

model LegalCase {
  id                   String          @id @default(cuid())
  tenantId             String
  buildingId           String?
  unitId               String?
  collectionCaseId     String?
  attorneyId           String?
  assignedUserId       String?
  marshalId            String?
  inLegal              Boolean         @default(true)
  stage                LegalStage      @default(NOTICE_SENT)
  caseNumber           String?
  attorney             String?
  filedDate            DateTime?
  courtDate            DateTime?
  arrearsBalance       Decimal?        @db.Decimal(10, 2)
  status               String          @default("active") // active, settled, dismissed, withdrawn
  importBatchId        String?
  isActive             Boolean         @default(true)
  marshalScheduledDate DateTime?
  marshalExecutedDate  DateTime?
  notes_text           String?         @db.Text
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building             Building?       @relation(fields: [buildingId], references: [id])
  unit                 Unit?           @relation(fields: [unitId], references: [id])
  collectionCase       CollectionCase? @relation(fields: [collectionCaseId], references: [id])
  attorneyContact      Vendor?         @relation("LegalCaseAttorney", fields: [attorneyId], references: [id])
  assignedUser         User?           @relation("LegalCaseAssignee", fields: [assignedUserId], references: [id])
  marshalContact       Vendor?         @relation("LegalCaseMarshal", fields: [marshalId], references: [id])
  notes                LegalNote[]

  @@index([tenantId])
  @@index([stage])
  @@index([status])
  @@index([buildingId])
  @@index([unitId])
  @@index([collectionCaseId])
  @@index([assignedUserId])
  @@index([attorneyId])
  @@index([marshalId])
  @@index([isActive])
  @@index([buildingId, isActive])
  @@map("legal_cases")
}

model LegalImportQueue {
  id                       String    @id @default(cuid())
  importBatchId            String
  rowIndex                 Int
  rawData                  Json
  matchType                String // exact, likely, needs_review, no_match
  matchConfidence          Decimal   @db.Decimal(3, 2)
  candidateTenantId        String?
  candidateTenantName      String?
  candidateBuildingAddress String?
  candidateUnitNumber      String?
  sourceAddress            String?
  sourceUnit               String?
  sourceTenantName         String?
  sourceCaseNumber         String?
  status                   String    @default("pending") // pending, approved, rejected, auto_matched
  resolvedById             String?
  resolvedAt               DateTime?
  createdAt                DateTime  @default(now())

  @@index([importBatchId])
  @@index([status])
  @@map("legal_import_queue")
}

model LegalNote {
  id          String     @id @default(cuid())
  legalCaseId String
  authorId    String
  text        String     @db.Text
  stage       LegalStage
  isSystem    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  legalCase   LegalCase  @relation(fields: [legalCaseId], references: [id], onDelete: Cascade)
  author      User       @relation(fields: [authorId], references: [id])

  @@index([legalCaseId, createdAt(sort: Desc)])
  @@index([authorId])
  @@map("legal_notes")
}

model Task {
  id          String    @id @default(cuid())
  tenantId    String
  createdById String
  type        String
  description String
  dueDate     DateTime?
  done        Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User      @relation(fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([createdById])
  @@index([dueDate])
  @@map("tasks")
}

model VacancyInfo {
  id            String    @id @default(cuid())
  unitId        String    @unique
  condition     String?
  accessType    String?
  accessNotes   String?
  proposedRent  Decimal?  @db.Decimal(10, 2)
  readyDate     DateTime?
  internalNotes String?   @db.Text
  brokerNotes   Json?
  updatedAt     DateTime  @updatedAt
  unit          Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@map("vacancy_info")
}

model DhcrRent {
  id          String   @id @default(cuid())
  buildingId  String
  unitNumber  String
  legalRent   Decimal  @db.Decimal(10, 2)
  regId       String?
  dhcrAddress String?
  importedAt  DateTime @default(now())

  @@unique([buildingId, unitNumber])
  @@map("dhcr_rents")
}

model ImportBatch {
  id          String    @id @default(cuid())
  buildingId  String?
  filename    String
  format      String
  recordCount Int       @default(0)
  status      String    @default("completed")
  errors      Json?
  importedAt  DateTime  @default(now())
  building    Building? @relation(fields: [buildingId], references: [id])

  @@index([buildingId])
  @@map("import_batches")
}

enum EmailType {
  DEMAND_LETTER
  PAYMENT_REMINDER
  LATE_NOTICE
  COLLECTION_REPORT
  LEASE_RENEWAL
  CUSTOM
}

model EmailLog {
  id             String    @id @default(cuid())
  tenantId       String?
  sentById       String
  type           EmailType
  subject        String
  body           String    @db.Text
  recipientEmail String
  status         String    @default("sent")
  sentAt         DateTime  @default(now())
  tenant         Tenant?   @relation(fields: [tenantId], references: [id])
  sentBy         User      @relation(fields: [sentById], references: [id])

  @@index([tenantId, sentAt(sort: Desc)])
  @@index([sentById])
  @@map("email_logs")
}

// ── Work Order & Maintenance ──────────────────────────────────────

enum WorkOrderStatus {
  PENDING_REVIEW
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkOrderCategory {
  PLUMBING
  ELECTRICAL
  HVAC
  APPLIANCE
  GENERAL
  OTHER
}

enum MaintenanceFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

model Vendor {
  id                   String                     @id @default(cuid())
  name                 String
  company              String?
  email                String?
  phone                String?
  specialty            String?
  contactType          String                     @default("vendor") // vendor | broker | attorney | marshal
  hourlyRate           Decimal?                   @db.Decimal(10, 2)
  notes                String?                    @db.Text
  organizationId       String?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  workOrders           WorkOrder[]
  complianceItems      ComplianceItem[]
  vacanciesBrokered    Vacancy[]                  @relation("VacancyBroker")
  legalCasesAsAttorney LegalCase[]                @relation("LegalCaseAttorney")
  legalCasesAsMarshal  LegalCase[]                @relation("LegalCaseMarshal")
  violationsAssigned   Violation[]                @relation("ViolationVendor")
  turnoverAssignments  TurnoverVendorAssignment[]
  trades               VendorTrade[]
  buildingAssignments  VendorAssignment[]

  @@index([contactType])
  @@index([organizationId])
  @@map("vendors")
}

model WorkOrder {
  id              String              @id @default(cuid())
  title           String
  description     String              @db.Text
  status          WorkOrderStatus     @default(OPEN)
  priority        WorkOrderPriority   @default(MEDIUM)
  category        WorkOrderCategory   @default(GENERAL)
  photos          Json?
  estimatedCost   Decimal?            @db.Decimal(10, 2)
  actualCost      Decimal?            @db.Decimal(10, 2)
  scheduledDate   DateTime?
  completedDate   DateTime?
  buildingId      String
  unitId          String?
  tenantId        String?
  vendorId        String?
  assignedToId    String?
  createdById     String?
  sourceType      String? // manual | inspection | violation | vacancy | move_out
  sourceId        String?
  violationId     String?
  trade           String?
  dueDate         DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  building        Building            @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit            Unit?               @relation(fields: [unitId], references: [id])
  tenant          Tenant?             @relation(fields: [tenantId], references: [id])
  vendor          Vendor?             @relation(fields: [vendorId], references: [id])
  violationDirect Violation?          @relation("WorkOrderViolation", fields: [violationId], references: [id])
  assignedTo      User?               @relation("WorkOrderAssignee", fields: [assignedToId], references: [id])
  createdBy       User?               @relation("WorkOrderCreator", fields: [createdById], references: [id])
  comments        WorkOrderComment[]
  activities      WorkOrderActivity[]
  violations      Violation[]
  inspectionItems InspectionItem[]
  evidence        Evidence[]

  @@index([buildingId])
  @@index([unitId])
  @@index([tenantId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([vendorId])
  @@index([violationId])
  @@index([status])
  @@index([priority])
  @@index([sourceType, sourceId])
  @@index([status, priority])
  @@index([buildingId, status])
  @@map("work_orders")
}

model WorkOrderComment {
  id          String    @id @default(cuid())
  workOrderId String
  authorId    String
  text        String    @db.Text
  photos      Json?
  createdAt   DateTime  @default(now())
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id])

  @@index([workOrderId, createdAt(sort: Desc)])
  @@map("work_order_comments")
}

model WorkOrderActivity {
  id          String    @id @default(cuid())
  workOrderId String
  userId      String?
  action      String // status_changed, priority_changed, vendor_assigned, user_assigned, due_date_set, completed
  fromValue   String?
  toValue     String?
  createdAt   DateTime  @default(now())
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  user        User?     @relation("WorkOrderActivityUser", fields: [userId], references: [id])

  @@index([workOrderId, createdAt(sort: Desc)])
  @@map("work_order_activities")
}

model MaintenanceSchedule {
  id                  String               @id @default(cuid())
  title               String
  description         String?              @db.Text
  frequency           MaintenanceFrequency
  nextDueDate         DateTime
  autoCreateWorkOrder Boolean              @default(true)
  lastRunDate         DateTime?
  buildingId          String
  unitId              String?
  building            Building             @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit                Unit?                @relation(fields: [unitId], references: [id])
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([buildingId])
  @@index([unitId])
  @@index([nextDueDate])
  @@map("maintenance_schedules")
}

// ── Compliance & Violations ─────────────────────────────────────

enum ViolationSource {
  HPD
  DOB
  ECB
  FDNY
  DSNY
  DOHMH
  DOB_COMPLAINTS
  HPD_COMPLAINTS
  HPD_LITIGATION
}

enum ViolationClass {
  A
  B
  C
  I
  CLASS1
  CLASS2
  CLASS3
}

enum ViolationSeverity {
  IMMEDIATELY_HAZARDOUS
  HAZARDOUS
  NON_HAZARDOUS
  INFO
}

enum EvidenceType {
  BEFORE
  AFTER
  TENANT_SIGNATURE
  SUPER_ATTESTATION
  MATERIAL_RECEIPT
  PM_VERIFICATION
  NO_ACCESS
}

enum CertStatus {
  PENDING_REVIEW
  READY
  SUBMITTED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ViolationLifecycle {
  INGESTED
  TRIAGED
  DISPATCHED
  IN_REPAIR
  EVIDENCE_PENDING
  PM_VERIFIED
  CERTIFICATION_READY
  CERTIFIED
  REJECTED
}

enum ComplianceCategory {
  LOCAL_LAW
  INSPECTION
  FILING
  CUSTOM
}

enum ComplianceFrequency {
  ANNUAL
  SEMI_ANNUAL
  QUARTERLY
  FIVE_YEAR
  FOUR_YEAR
  ONE_TIME
  ON_EVENT
}

enum ComplianceStatus {
  COMPLIANT
  NON_COMPLIANT
  PENDING
  OVERDUE
  SCHEDULED
  NOT_APPLICABLE
}

model Violation {
  id                   String             @id @default(cuid())
  buildingId           String
  unitId               String?
  assignedUserId       String?
  assignedVendorId     String?
  source               ViolationSource
  externalId           String
  class                ViolationClass?
  severity             ViolationSeverity?
  description          String             @db.Text
  inspectionDate       DateTime?
  issuedDate           DateTime?
  currentStatus        String?
  penaltyAmount        Decimal            @default(0) @db.Decimal(10, 2)
  normalizedCategory   String?
  reconciliationStatus String             @default("UNMATCHED")
  sourceType           String?
  sourceId             String?
  complaintId          String?
  needsWorkOrder       Boolean            @default(true)
  certifyByDate        DateTime?
  respondByDate        DateTime?
  certifiedDismissDate DateTime?
  correctionDate       DateTime?
  targetCompletionDate DateTime?
  certificationDate    DateTime?
  remediationNotes     String?            @db.Text
  isOpen               Boolean            @default(true)
  unitNumber           String?
  novDescription       String?            @db.Text
  hearingDate          DateTime?
  hearingStatus        String?
  linkedWorkOrderId    String?
  sourceUrl            String?
  lifecycleStatus      String             @default("INGESTED")
  triagedAt            DateTime?
  dispatchedAt         DateTime?
  evidenceSubmittedAt  DateTime?
  pmVerifiedAt         DateTime?
  pmVerifiedById       String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  building             Building           @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit                 Unit?              @relation(fields: [unitId], references: [id])
  assignedUser         User?              @relation(fields: [assignedUserId], references: [id])
  assignedVendor       Vendor?            @relation("ViolationVendor", fields: [assignedVendorId], references: [id])
  linkedWorkOrder      WorkOrder?         @relation(fields: [linkedWorkOrderId], references: [id])
  workOrdersFromSource WorkOrder[]        @relation("WorkOrderViolation")
  complaint            Complaint?         @relation(fields: [complaintId], references: [id])
  pmVerifiedBy         User?              @relation("ViolationPMVerifier", fields: [pmVerifiedById], references: [id])
  complianceItems      ComplianceItem[]
  certificationItems   CertificationPacketItem[]

  @@unique([source, externalId])
  @@index([buildingId])
  @@index([unitId])
  @@index([assignedUserId])
  @@index([assignedVendorId])
  @@index([linkedWorkOrderId])
  @@index([complaintId])
  @@index([source])
  @@index([currentStatus])
  @@index([isOpen])
  @@index([hearingDate])
  @@index([respondByDate])
  @@index([lifecycleStatus])
  @@index([pmVerifiedById])
  @@index([source, currentStatus])
  @@index([buildingId, isOpen])
  @@map("violations")
}

model ComplianceItem {
  id                String              @id @default(cuid())
  buildingId        String
  type              String
  category          ComplianceCategory
  name              String
  description       String              @db.Text
  dueDate           DateTime?
  frequency         ComplianceFrequency
  status            ComplianceStatus    @default(PENDING)
  lastCompletedDate DateTime?
  nextDueDate       DateTime?
  assignedVendorId  String?
  cost              Decimal             @default(0) @db.Decimal(10, 2)
  filedBy           String?
  certificateUrl    String?
  notes             String?             @db.Text
  linkedViolationId String?
  isCustom          Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  building          Building            @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  assignedVendor    Vendor?             @relation(fields: [assignedVendorId], references: [id])
  linkedViolation   Violation?          @relation(fields: [linkedViolationId], references: [id])

  @@index([buildingId])
  @@index([assignedVendorId])
  @@index([linkedViolationId])
  @@index([status])
  @@index([nextDueDate])
  @@index([category])
  @@map("compliance_items")
}

model ViolationSyncLog {
  id           String          @id @default(cuid())
  buildingId   String?
  source       ViolationSource
  syncedAt     DateTime        @default(now())
  newCount     Int             @default(0)
  updatedCount Int             @default(0)
  status       String          @default("completed")
  building     Building?       @relation(fields: [buildingId], references: [id])

  @@index([buildingId, syncedAt(sort: Desc)])
  @@map("violation_sync_logs")
}

// ── Phase 1: Normalized Domain Models ──────────────────────────────

enum LeaseStatus {
  ACTIVE
  EXPIRED
  MONTH_TO_MONTH
  RENEWED
  TERMINATED
  PENDING
}

enum OccupancyStatus {
  OCCUPIED
  VACANT
  NOTICE_GIVEN
  EVICTION_IN_PROGRESS
}

enum OccupantRole {
  PRIMARY
  SPOUSE
  DEPENDENT
  ROOMMATE
  GUARANTOR
  AUTHORIZED_REP
}

enum PaymentFrequency {
  MONTHLY
  WEEKLY
  BIWEEKLY
}

enum BillingStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum ImportType {
  RENT_ROLL
  AGING
  BUILDING
  DHCR
  TENANT_MASTER
}

enum ImportRowStatus {
  MATCHED
  CREATED
  UPDATED
  SKIPPED
  ERROR
}

model Lease {
  id               String            @id @default(cuid())
  organizationId   String?
  buildingId       String?
  unitId           String
  tenantId         String?
  isCurrent        Boolean           @default(true)
  leaseStart       DateTime?
  leaseEnd         DateTime?
  moveInDate       DateTime?
  moveOutDate      DateTime?
  monthlyRent      Decimal           @default(0) @db.Decimal(10, 2)
  legalRent        Decimal           @default(0) @db.Decimal(10, 2)
  preferentialRent Decimal           @default(0) @db.Decimal(10, 2)
  subsidyType      String?
  subsidyAmount    Decimal           @default(0) @db.Decimal(10, 2)
  tenantPortion    Decimal           @default(0) @db.Decimal(10, 2)
  renewalStatus    String?
  leaseType        String?
  status           LeaseStatus       @default(ACTIVE)
  paymentFrequency PaymentFrequency  @default(MONTHLY)
  billingStatus    BillingStatus     @default(ACTIVE)
  isStabilized     Boolean           @default(false)
  householdSize    Int?
  securityDeposit  Decimal           @default(0) @db.Decimal(10, 2)
  currentBalance   Decimal           @default(0) @db.Decimal(10, 2)
  chargeCode       String?
  notes            String?           @db.Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  organization     Organization?     @relation(fields: [organizationId], references: [id])
  building         Building?         @relation(fields: [buildingId], references: [id])
  unit             Unit              @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant           Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  occupants        LeaseOccupant[]
  recurringCharges RecurringCharge[]
  balanceSnapshots BalanceSnapshot[]
  paymentPlans     PaymentPlan[]

  @@index([organizationId])
  @@index([buildingId])
  @@index([unitId])
  @@index([tenantId])
  @@index([status])
  @@index([isCurrent])
  @@index([leaseEnd])
  @@index([organizationId, isCurrent])
  @@map("leases")
}

model LeaseOccupant {
  id        String       @id @default(cuid())
  leaseId   String
  name      String
  role      OccupantRole @default(PRIMARY)
  isPrimary Boolean      @default(false)
  phone     String?
  email     String?
  createdAt DateTime     @default(now())
  lease     Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId])
  @@map("lease_occupants")
}

model RecurringCharge {
  id          String           @id @default(cuid())
  leaseId     String
  chargeCode  String
  description String?
  amount      Decimal          @db.Decimal(10, 2)
  frequency   PaymentFrequency @default(MONTHLY)
  startDate   DateTime?
  endDate     DateTime?
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  lease       Lease            @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId])
  @@index([active])
  @@map("recurring_charges")
}

model BalanceSnapshot {
  id                String    @id @default(cuid())
  tenantId          String?
  leaseId           String?
  importBatchId     String?
  snapshotDate      DateTime  @default(now())
  currentCharges    Decimal   @default(0) @db.Decimal(10, 2)
  currentBalance    Decimal   @default(0) @db.Decimal(10, 2)
  pastDueBalance    Decimal   @default(0) @db.Decimal(10, 2)
  lastPaymentDate   DateTime?
  lastPaymentAmount Decimal?  @db.Decimal(10, 2)
  arrearsStatus     String    @default("current")
  createdAt         DateTime  @default(now())
  tenant            Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  lease             Lease?    @relation(fields: [leaseId], references: [id], onDelete: SetNull)

  @@index([tenantId, snapshotDate(sort: Desc)])
  @@index([leaseId])
  @@index([snapshotDate])
  @@map("balance_snapshots")
}

model ImportRow {
  id            String          @id @default(cuid())
  importBatchId String
  rowIndex      Int
  rawData       Json
  status        ImportRowStatus @default(MATCHED)
  entityType    String?
  entityId      String?
  errors        Json?
  createdAt     DateTime        @default(now())

  @@index([importBatchId])
  @@index([status])
  @@map("import_rows")
}

// ── Self-Learning Import Profiles ────────────────────────────────

model ImportProfile {
  id               String           @id @default(cuid())
  organizationId   String           @default("default")
  name             String
  importType       String
  sheetNamePattern String?
  headerRowCount   Int
  fingerprintJson  Json
  mappingJson      Json
  ignoredRulesJson Json?
  isActive         Boolean          @default(true)
  createdById      String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  runs             ImportRun[]
  feedback         ImportFeedback[]

  @@index([organizationId, importType])
  @@map("import_profiles")
}

model ImportRun {
  id               String           @id @default(cuid())
  organizationId   String           @default("default")
  fileName         String
  importType       String
  matchedProfileId String?
  aiUsed           Boolean          @default(false)
  status           String           @default("pending")
  analysisJson     Json
  finalMappingJson Json?
  createdById      String?
  createdAt        DateTime         @default(now())
  matchedProfile   ImportProfile?   @relation(fields: [matchedProfileId], references: [id])
  feedback         ImportFeedback[]

  @@index([organizationId, importType])
  @@index([matchedProfileId])
  @@map("import_runs")
}

model ImportFeedback {
  id                 String         @id @default(cuid())
  importRunId        String
  importProfileId    String?
  fieldName          String
  originalSuggestion String?
  finalUserChoice    String?
  corrected          Boolean        @default(false)
  createdAt          DateTime       @default(now())
  importRun          ImportRun      @relation(fields: [importRunId], references: [id], onDelete: Cascade)
  importProfile      ImportProfile? @relation(fields: [importProfileId], references: [id])

  @@index([importRunId])
  @@index([importProfileId])
  @@map("import_feedback")
}

// ── Core Entity Models ──────────────────────────────────────────

model Organization {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  plan           String          @default("trial")
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  users          User[]
  buildings      Building[]
  leases         Lease[]
  activityEvents ActivityEvent[]

  @@map("organizations")
}

model Owner {
  id        String     @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  notes     String?    @db.Text
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  buildings Building[]

  @@map("owners")
}

// ── Operational Records ─────────────────────────────────────────

model CollectionCase {
  id             String      @id @default(cuid())
  buildingId     String
  unitId         String
  tenantId       String
  assignedUserId String?
  balanceOwed    Decimal     @default(0) @db.Decimal(10, 2)
  daysLate       Int         @default(0)
  status         String      @default("new_arrears") // new_arrears | reminder_sent | payment_plan | notice_served | legal_review | legal_filed
  lastActionDate DateTime?
  nextActionDate DateTime?
  notes          String?     @db.Text
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  building       Building    @relation(fields: [buildingId], references: [id])
  unit           Unit        @relation(fields: [unitId], references: [id])
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  assignedUser   User?       @relation("CollectionAssignee", fields: [assignedUserId], references: [id])
  legalCases     LegalCase[]

  @@index([buildingId])
  @@index([unitId])
  @@index([tenantId])
  @@index([assignedUserId])
  @@index([status])
  @@index([isActive])
  @@index([buildingId, status])
  @@map("collection_cases")
}

model Vacancy {
  id              String    @id @default(cuid())
  buildingId      String
  unitId          String
  brokerId        String?
  assignedUserId  String?
  stage           String    @default("vacant") // vacant | renovation | listed | showing | application | lease_signed
  askingRent      Decimal?  @db.Decimal(10, 2)
  showingsCount   Int       @default(0)
  listedDate      DateTime?
  applicationDate DateTime?
  leaseSignedDate DateTime?
  moveInDate      DateTime?
  notes           String?   @db.Text
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  building        Building  @relation(fields: [buildingId], references: [id])
  unit            Unit      @relation(fields: [unitId], references: [id])
  broker          Vendor?   @relation("VacancyBroker", fields: [brokerId], references: [id])
  assignedUser    User?     @relation("VacancyAssignee", fields: [assignedUserId], references: [id])

  @@index([buildingId])
  @@index([unitId])
  @@index([assignedUserId])
  @@index([brokerId])
  @@index([isActive])
  @@index([stage])
  @@map("vacancies")
}

model LeasingActivity {
  id          String   @id @default(cuid())
  unitId      String
  buildingId  String
  userId      String
  type        String // showing, application, follow_up, offer_sent, lease_signed, inquiry, note
  description String?  @db.Text
  contactName String?
  contactInfo String?
  createdAt   DateTime @default(now())
  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  building    Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@index([unitId])
  @@index([buildingId])
  @@index([userId])
  @@index([createdAt])
  @@map("leasing_activities")
}

model Inspection {
  id                 String              @id @default(cuid())
  buildingId         String
  unitId             String?
  assignedUserId     String?
  templateId         String?
  inspectionType     String
  frequencyType      String              @default("one_time") // monthly | weekly | move_in | move_out | one_time
  scheduledFor       DateTime?
  completedAt        DateTime?
  overallStatus      String              @default("pending") // pending | in_progress | completed | cancelled
  notes              String?             @db.Text
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  building           Building            @relation(fields: [buildingId], references: [id])
  unit               Unit?               @relation(fields: [unitId], references: [id])
  assignedUser       User?               @relation("InspectionAssignee", fields: [assignedUserId], references: [id])
  template           InspectionTemplate? @relation(fields: [templateId], references: [id])
  items              InspectionItem[]
  moveOutAssessments MoveOutAssessment[]

  @@index([buildingId])
  @@index([unitId])
  @@index([assignedUserId])
  @@index([templateId])
  @@index([scheduledFor])
  @@index([overallStatus])
  @@map("inspections")
}

model InspectionItem {
  id                   String                  @id @default(cuid())
  inspectionId         String
  buildingId           String
  unitId               String?
  templateItemId       String?
  label                String
  status               String                  @default("pending") // pass | fail | needs_attention | na | pending
  notes                String?                 @db.Text
  generatedWorkOrderId String?
  createdAt            DateTime                @default(now())
  inspection           Inspection              @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  building             Building                @relation(fields: [buildingId], references: [id])
  unit                 Unit?                   @relation(fields: [unitId], references: [id])
  generatedWorkOrder   WorkOrder?              @relation(fields: [generatedWorkOrderId], references: [id])
  templateItem         InspectionTemplateItem? @relation(fields: [templateItemId], references: [id])

  @@index([inspectionId])
  @@index([buildingId])
  @@index([unitId])
  @@index([templateItemId])
  @@map("inspection_items")
}

model MoveOutAssessment {
  id                       String          @id @default(cuid())
  buildingId               String
  unitId                   String
  tenantId                 String
  inspectionId             String?
  assignedUserId           String?
  securityDepositAmount    Decimal         @default(0) @db.Decimal(10, 2)
  recommendedChargesTotal  Decimal         @default(0) @db.Decimal(10, 2)
  recommendedDepositReturn Decimal         @default(0) @db.Decimal(10, 2)
  recommendationStatus     String          @default("draft") // draft | reviewed | approved | sent
  draftEmailBody           String?         @db.Text
  completedAt              DateTime?
  notes                    String?         @db.Text
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  building                 Building        @relation(fields: [buildingId], references: [id])
  unit                     Unit            @relation(fields: [unitId], references: [id])
  tenant                   Tenant          @relation(fields: [tenantId], references: [id])
  inspection               Inspection?     @relation(fields: [inspectionId], references: [id])
  assignedUser             User?           @relation("MoveOutAssignee", fields: [assignedUserId], references: [id])
  charges                  MoveOutCharge[]

  @@index([buildingId])
  @@index([unitId])
  @@index([tenantId])
  @@index([assignedUserId])
  @@index([inspectionId])
  @@map("move_out_assessments")
}

model MoveOutCharge {
  id                  String            @id @default(cuid())
  moveOutAssessmentId String
  buildingId          String
  unitId              String
  tenantId            String
  chargeCode          String
  chargeLabel         String
  quantity            Int               @default(1)
  unitPrice           Decimal           @db.Decimal(10, 2)
  totalPrice          Decimal           @db.Decimal(10, 2)
  notes               String?           @db.Text
  createdAt           DateTime          @default(now())
  assessment          MoveOutAssessment @relation(fields: [moveOutAssessmentId], references: [id], onDelete: Cascade)
  building            Building          @relation(fields: [buildingId], references: [id])
  unit                Unit              @relation(fields: [unitId], references: [id])
  tenant              Tenant            @relation(fields: [tenantId], references: [id])

  @@index([moveOutAssessmentId])
  @@index([buildingId])
  @@index([unitId])
  @@index([tenantId])
  @@map("move_out_charges")
}

// ── Import Staging ─────────────────────────────────────────────

model ImportStagingBatch {
  id            String    @id @default(cuid())
  importType    String    @default("tenant_list") // tenant_list | rent_roll | aging | building
  fileName      String
  uploadedById  String
  status        String    @default("pending_review") // pending_review | approved | rejected | expired
  rowsJson      Json // Array of parsed row objects
  mappingJson   Json // Column mapping used
  summaryJson   Json // { total, newTenants, updates, errors, buildings }
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNotes   String?   @db.Text
  importBatchId String? // set after approval creates the real ImportBatch
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([uploadedById])
  @@map("import_staging_batches")
}

// ── Shared Activity Timeline ────────────────────────────────────

model ActivityEvent {
  id                String        @id @default(cuid())
  eventType         String // legal_case_created | work_order_completed | payment_received | vacancy_listed | inspection_completed | collection_escalated | ...
  title             String
  description       String?       @db.Text
  organizationId    String?
  buildingId        String?
  unitId            String?
  tenantId          String?
  relatedRecordType String? // LegalCase | WorkOrder | CollectionCase | Vacancy | Inspection | MoveOutAssessment | ...
  relatedRecordId   String?
  createdByUserId   String?
  eventTimestamp    DateTime      @default(now())
  metadata          Json?
  createdAt         DateTime      @default(now())
  organization      Organization? @relation(fields: [organizationId], references: [id])
  building          Building?     @relation(fields: [buildingId], references: [id])
  unit              Unit?         @relation(fields: [unitId], references: [id])
  tenant            Tenant?       @relation(fields: [tenantId], references: [id])
  createdByUser     User?         @relation(fields: [createdByUserId], references: [id])

  @@index([buildingId, eventTimestamp(sort: Desc)])
  @@index([unitId, eventTimestamp(sort: Desc)])
  @@index([tenantId, eventTimestamp(sort: Desc)])
  @@index([organizationId, eventTimestamp(sort: Desc)])
  @@index([relatedRecordType, relatedRecordId])
  @@index([eventType])
  @@map("activity_events")
}

// ── Complaints ────────────────────────────────────────────────

model Complaint {
  id           String      @id @default(uuid())
  buildingId   String
  unitId       String?
  source       String
  category     String
  description  String      @db.Text
  reportedBy   String?
  reportedDate DateTime?
  status       String      @default("OPEN")
  resolvedDate DateTime?
  notes        String?     @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  building     Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit         Unit?       @relation(fields: [unitId], references: [id])
  violations   Violation[]

  @@index([buildingId])
  @@index([unitId])
  @@index([status])
  @@index([source])
  @@map("complaints")
}

// ── Collections & AR ──────────────────────────────────────────

enum CollectionActionType {
  CALLED
  LEFT_VOICEMAIL
  TEXTED
  EMAILED
  NOTICE_SENT
  PAYMENT_PLAN
  PARTIAL_PAYMENT
  PROMISE_TO_PAY
  SENT_TO_LEGAL
  OTHER
}

enum CollectionStatus {
  CURRENT
  LATE
  DELINQUENT
  CHRONIC
  PAYMENT_PLAN
  LEGAL
  VACATE_PENDING
}

model CollectionNote {
  id           String               @id @default(cuid())
  tenantId     String
  buildingId   String
  authorId     String
  content      String               @db.Text
  actionType   CollectionActionType
  followUpDate DateTime?
  createdAt    DateTime             @default(now())
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building     Building             @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  author       User                 @relation(fields: [authorId], references: [id])

  @@index([tenantId])
  @@index([buildingId])
  @@index([authorId])
  @@index([followUpDate])
  @@map("collection_notes")
}

model ARSnapshot {
  id               String           @id @default(cuid())
  tenantId         String
  buildingId       String
  month            DateTime
  balance0_30      Decimal          @db.Decimal(10, 2)
  balance31_60     Decimal          @db.Decimal(10, 2)
  balance61_90     Decimal          @db.Decimal(10, 2)
  balance90plus    Decimal          @db.Decimal(10, 2)
  totalBalance     Decimal          @db.Decimal(10, 2)
  collectionStatus CollectionStatus
  snapshotDate     DateTime
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building         Building         @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([tenantId, month])
  @@index([buildingId])
  @@index([month])
  @@map("ar_snapshots")
}

// ── Utility Meter & Account Compliance ───────────────────────────

model UtilityMeter {
  id             String   @id @default(cuid())
  buildingId     String
  unitId         String?
  utilityType    String // "electric" | "gas" | "water" | "common_electric" | "common_gas"
  providerName   String?
  meterNumber    String?
  serviceAddress String?
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  building Building         @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit     Unit?            @relation(fields: [unitId], references: [id], onDelete: SetNull)
  accounts UtilityAccount[]

  @@index([buildingId])
  @@index([unitId])
  @@map("utility_meters")
}

model UtilityAccount {
  id                String    @id @default(cuid())
  utilityMeterId    String
  accountNumber     String?
  assignedPartyType String // "tenant" | "owner" | "management" | "unknown"
  assignedPartyName String?
  tenantId          String?
  startDate         DateTime?
  endDate           DateTime?
  status            String    @default("active") // "active" | "closed" | "pending"
  closedWithBalance Boolean?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  meter         UtilityMeter          @relation(fields: [utilityMeterId], references: [id], onDelete: Cascade)
  tenant        Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  monthlyChecks UtilityMonthlyCheck[]

  @@index([utilityMeterId])
  @@index([tenantId])
  @@index([status])
  @@map("utility_accounts")
}

model UtilityMonthlyCheck {
  id               String    @id @default(cuid())
  utilityAccountId String
  month            Int
  year             Int
  paymentStatus    String // "paid" | "unpaid" | "pending_verification" | "unknown" | "no_bill"
  verifiedBy       String?
  verifiedAt       DateTime?
  proofFileUrl     String?
  notes            String?
  createdAt        DateTime  @default(now())

  account UtilityAccount @relation(fields: [utilityAccountId], references: [id], onDelete: Cascade)

  @@unique([utilityAccountId, month, year])
  @@map("utility_monthly_checks")
}

// ── Operational Intelligence Engine ──────────────────────────────

model OperationalSignal {
  id                String    @id @default(cuid())
  deduplicationKey  String    @unique // e.g. "collections-risk-high-[tenantId]"
  type              String // collections_risk | legal_escalation | vacancy_risk | violation_risk | maintenance_failure | lease_expiration | utility_problem
  severity          String // low | medium | high | critical
  title             String
  description       String    @db.Text
  entityType        String // tenant | building | unit | workorder | violation | lease | meter | complaint
  entityId          String
  buildingId        String?
  tenantId          String?
  organizationId    String?
  status            String    @default("active") // active | acknowledged | resolved
  lastTriggeredAt   DateTime  @default(now())
  acknowledgedAt    DateTime?
  resolvedAt        DateTime?
  assignedToUserId  String?
  dueAt             DateTime?
  snoozedUntil      DateTime?
  recommendedAction String?   @db.Text
  resolutionNote    String?   @db.Text
  acknowledgedById  String?
  resolvedById      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  assignedToUser    User?     @relation("SignalAssignee", fields: [assignedToUserId], references: [id])
  acknowledgedBy    User?     @relation("SignalAcknowledger", fields: [acknowledgedById], references: [id])
  resolvedBy        User?     @relation("SignalResolver", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([severity])
  @@index([type])
  @@index([buildingId])
  @@index([tenantId])
  @@index([organizationId])
  @@index([assignedToUserId])
  @@index([dueAt])
  @@map("operational_signals")
}

model SignalScanLog {
  id              String    @id @default(cuid())
  scanType        String // manual | scheduled
  triggeredById   String?
  organizationId  String?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  durationMs      Int?
  success         Boolean   @default(true)
  errorMessage    String?   @db.Text
  createdSignals  Int       @default(0)
  updatedSignals  Int       @default(0)
  resolvedSignals Int       @default(0)
  triggeredBy     User?     @relation(fields: [triggeredById], references: [id])

  @@index([triggeredById])
  @@index([organizationId])
  @@index([startedAt])
  @@map("signal_scan_logs")
}

// ── Turnover Workflow ────────────────────────────────────────

enum TurnoverTrigger {
  MANUAL
  AUTO
}

enum TurnoverStatus {
  PENDING_INSPECTION
  INSPECTION_DONE
  SCOPE_CREATED
  VENDORS_ASSIGNED
  READY_TO_LIST
  LISTED
  COMPLETE
}

enum TurnoverVendorStatus {
  PENDING
  SCHEDULED
  COMPLETED
}

model TurnoverWorkflow {
  id                  String          @id @default(cuid())
  unitId              String
  buildingId          String
  triggeredBy         TurnoverTrigger @default(MANUAL)
  moveOutDate         DateTime?
  moveOutSource       String? // "LEASE_END" | "MANUAL"
  status              TurnoverStatus  @default(PENDING_INSPECTION)
  inspectionDate      DateTime?
  inspectionNotes     String?         @db.Text
  inspectionChecklist Json?
  scopeOfWork         String?         @db.Text
  estimatedCost       Decimal?        @db.Decimal(10, 2)
  listedDate          DateTime?
  completedAt         DateTime?
  assignedToUserId    String?
  isActive            Boolean         @default(true)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  unit              Unit                       @relation(fields: [unitId], references: [id], onDelete: Cascade)
  building          Building                   @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  assignedTo        User?                      @relation("TurnoverAssignee", fields: [assignedToUserId], references: [id])
  vendorAssignments TurnoverVendorAssignment[]

  @@index([unitId])
  @@index([buildingId])
  @@index([assignedToUserId])
  @@index([status])
  @@index([isActive])
  @@map("turnover_workflows")
}

model TurnoverVendorAssignment {
  id                 String               @id @default(cuid())
  turnoverWorkflowId String
  vendorId           String?
  vendorName         String
  trade              String // paint, plumbing, electric, hvac, flooring, general, cleaning, other
  status             TurnoverVendorStatus @default(PENDING)
  scheduledDate      DateTime?
  completedDate      DateTime?
  cost               Decimal?             @db.Decimal(10, 2)
  notes              String?              @db.Text
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  turnoverWorkflow TurnoverWorkflow @relation(fields: [turnoverWorkflowId], references: [id], onDelete: Cascade)
  vendor           Vendor?          @relation(fields: [vendorId], references: [id])

  @@index([turnoverWorkflowId])
  @@index([vendorId])
  @@map("turnover_vendor_assignments")
}

// ── Inspection Templates ─────────────────────────────────────────

model InspectionTemplate {
  id             String                   @id @default(cuid())
  organizationId String?
  name           String
  inspectionType String // property_walkthrough | unit_condition | move_in | move_out | safety | custom
  description    String?                  @db.Text
  isDefault      Boolean                  @default(false)
  isActive       Boolean                  @default(true)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  items          InspectionTemplateItem[]
  inspections    Inspection[]

  @@index([organizationId])
  @@index([inspectionType])
  @@index([isActive])
  @@map("inspection_templates")
}

model InspectionTemplateItem {
  id              String             @id @default(cuid())
  templateId      String
  label           String
  category        String? // structure | plumbing | electrical | hvac | fire_safety | general | appliances | exterior
  sortOrder       Int                @default(0)
  isRequired      Boolean            @default(true)
  createdAt       DateTime           @default(now())
  template        InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  inspectionItems InspectionItem[]

  @@index([templateId])
  @@map("inspection_template_items")
}

// ── Vendor Trades & Assignments ─────────────────────────────────

model VendorTrade {
  id        String   @id @default(cuid())
  vendorId  String
  trade     String // plumbing | electrical | hvac | painting | flooring | general | cleaning | carpentry | roofing | fire_safety | elevator | other
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, trade])
  @@index([trade])
  @@map("vendor_trades")
}

model VendorAssignment {
  id         String    @id @default(cuid())
  vendorId   String
  buildingId String
  role       String // superintendent | elevator_company | fire_alarm_company | plumber | electrician | general_contractor | other
  isPrimary  Boolean   @default(false)
  notes      String?
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  vendor     Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  building   Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([vendorId, buildingId, role])
  @@index([vendorId])
  @@index([buildingId])
  @@index([role])
  @@map("vendor_assignments")
}

// ── Payment Plans ────────────────────────────────────────────────

model PaymentPlan {
  id                String    @id @default(cuid())
  organizationId    String?
  leaseId           String
  tenantId          String?
  totalAmount       Decimal   @db.Decimal(10, 2)
  installmentAmount Decimal   @db.Decimal(10, 2)
  installmentCount  Int
  startDate         DateTime
  nextDueDate       DateTime?
  status            String    @default("active") // active | completed | defaulted | cancelled
  notes             String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lease             Lease     @relation(fields: [leaseId], references: [id])
  tenant            Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([organizationId])
  @@index([leaseId])
  @@index([tenantId])
  @@index([status])
  @@map("payment_plans")
}

model SnoozedAction {
  id           String   @id @default(cuid())
  actionKey    String // deterministic key e.g. "signal-[signalId]"
  userId       String
  snoozedUntil DateTime
  createdAt    DateTime @default(now())

  @@unique([actionKey, userId])
  @@index([userId, snoozedUntil])
  @@map("snoozed_actions")
}

model RiskSnapshot {
  id           String   @id @default(cuid())
  buildingId   String
  building     Building @relation(fields: [buildingId], references: [id])
  snapshotDate DateTime @default(now())
  riskScore    Float
  riskCategory String
  factors      Json?
  createdAt    DateTime @default(now())

  @@index([buildingId])
  @@index([snapshotDate])
  @@map("risk_snapshots")
}

// ── V2W Compliance System ───────────────────────────────────────

model Evidence {
  id          String       @id @default(cuid())
  workOrderId String
  type        EvidenceType
  imageUrl    String
  lat         Float?
  lng         Float?
  capturedAt  DateTime     @default(now())
  notes       String?      @db.Text
  createdAt   DateTime     @default(now())
  workOrder   WorkOrder    @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@map("evidence")
}

model ViolationRuleMapping {
  id                    String            @id @default(cuid())
  organizationId        String?
  agency                String
  defectPattern         String            @db.Text
  internalTrade         String
  internalCategory      WorkOrderCategory
  defaultPriority       WorkOrderPriority @default(MEDIUM)
  dispatchSLAMinutes    Int               @default(480)
  escalationMinutes     Int               @default(60)
  certificationRequired Boolean           @default(true)
  confidenceScore       Decimal           @default(1.0) @db.Decimal(3, 2)
  isActive              Boolean           @default(true)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([agency])
  @@map("violation_rule_mappings")
}

model CertificationPacket {
  id              String     @id @default(cuid())
  organizationId  String?
  buildingId      String
  agency          String
  status          CertStatus @default(PENDING_REVIEW)
  preparedById    String?
  reviewedById    String?
  verifiedAt      DateTime?
  submittedAt     DateTime?
  certifyByDate   DateTime?
  submissionId    String?
  rejectionReason String?    @db.Text
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  building        Building   @relation(fields: [buildingId], references: [id])
  preparedBy      User?      @relation("CertPacketPreparer", fields: [preparedById], references: [id])
  reviewedBy      User?      @relation("CertPacketReviewer", fields: [reviewedById], references: [id])
  items           CertificationPacketItem[]

  @@index([buildingId, status])
  @@index([certifyByDate])
  @@map("certification_packets")
}

model CertificationPacketItem {
  id          String              @id @default(cuid())
  packetId    String
  violationId String
  addedAt     DateTime            @default(now())
  packet      CertificationPacket @relation(fields: [packetId], references: [id], onDelete: Cascade)
  violation   Violation           @relation(fields: [violationId], references: [id])

  @@unique([packetId, violationId])
  @@index([violationId])
  @@map("certification_packet_items")
}

// ── Prometheus Module ─────────────────────────────────────────────

model PrometheusIntake {
  id               String          @id @default(cuid())
  organizationId   String?
  buildingId       String?
  unitId           String?
  tenantId         String?
  source           String
  rawSubject       String?
  rawBody          String?         @db.Text
  rawSender        String?
  attachmentUrls   Json?
  extractedDate    DateTime?
  extractedIssue   String?         @db.Text
  extractedUnit    String?
  extractedContact String?
  aiSummary        String?         @db.Text
  status           String          @default("pending")
  convertedWOId    String?
  createdByUserId  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  building         Building?       @relation(fields: [buildingId], references: [id])
  createdBy        User?           @relation("PrometheusCreator", fields: [createdByUserId], references: [id])
  draft            WorkOrderDraft?

  @@index([buildingId, status])
  @@index([organizationId])
  @@map("prometheus_intakes")
}

model WorkOrderDraft {
  id               String            @id @default(cuid())
  intakeId         String?           @unique
  organizationId   String?
  buildingId       String
  unitId           String?
  tenantId         String?
  title            String
  description      String            @db.Text
  category         WorkOrderCategory @default(GENERAL)
  priority         WorkOrderPriority @default(MEDIUM)
  trade            String?
  assignedToId     String?
  vendorId         String?
  scheduledDate    DateTime?
  incidentDate     DateTime?
  accessAttempts   Json?
  verifiedByUserId String?
  verifiedAt       DateTime?
  flaggedIssues    Json?
  similarWOIds     Json?
  photoUrls        Json?
  promotedToWOId   String?
  status           String            @default("draft")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  building         Building          @relation(fields: [buildingId], references: [id])
  intake           PrometheusIntake? @relation(fields: [intakeId], references: [id])
  verifiedBy       User?             @relation("DraftVerifier", fields: [verifiedByUserId], references: [id])

  @@index([buildingId, status])
  @@index([organizationId])
  @@map("work_order_drafts")
}
