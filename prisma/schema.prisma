// ── RGB Orders (Rent Guidelines Board) ──────────────────────────

model RgbOrder {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  effectiveFrom   DateTime
  effectiveTo     DateTime
  oneYearPct      Decimal       @db.Decimal(5, 4)
  twoYearPct      Decimal       @db.Decimal(5, 4)
  twoYearY1Pct    Decimal?      @db.Decimal(5, 4)
  twoYearY2Pct    Decimal?      @db.Decimal(5, 4)
  notes           String?
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  createdAt       DateTime      @default(now())

  @@map("rgb_orders")
}

// ── Project Tracker ─────────────────────────────────────────────

enum ProjectCategory {
  TURNOVER
  CAPITAL_IMPROVEMENT
  VIOLATION_REMEDIATION
  LOCAL_LAW
  FACADE
  ROOF
  BOILER
  PLUMBING
  ELECTRICAL
  APARTMENT_RENO
  COMMON_AREA
  EMERGENCY
  ELEVATOR
  FIRE_SAFETY
  GENERAL_MAINTENANCE
  COSMETIC
  OTHER
}

enum ProjectStatus {
  PLANNED
  ESTIMATING
  PENDING_APPROVAL
  APPROVED
  IN_PROGRESS
  PAUSED
  SUBSTANTIALLY_COMPLETE
  COMPLETED
  CLOSED
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProjectHealth {
  ON_TRACK
  AT_RISK
  DELAYED
  OVER_BUDGET
  BLOCKED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum ChangeOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model Project {
  id               String            @id @default(cuid())
  orgId            String
  buildingId       String
  unitId           String?
  createdById      String
  managerId        String?
  vendorId         String?
  approvedById     String?
  code             String?
  name             String
  description      String?           @db.Text
  category         ProjectCategory
  status           ProjectStatus     @default(PLANNED)
  priority         ProjectPriority   @default(MEDIUM)
  health           ProjectHealth     @default(ON_TRACK)
  scopeOfWork      String?           @db.Text
  percentComplete  Int               @default(0)
  estimatedBudget  Decimal?          @db.Decimal(12, 2)
  approvedBudget   Decimal?          @db.Decimal(12, 2)
  actualCost       Decimal?          @db.Decimal(12, 2)
  contingency      Decimal?          @db.Decimal(12, 2)
  ownerVisible     Boolean           @default(false)
  requiresApproval Boolean           @default(false)
  approvedAt       DateTime?
  startDate        DateTime?
  targetEndDate    DateTime?
  actualEndDate    DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  building         Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  milestones       ProjectMilestone[]
  budgetLines      ProjectBudgetLine[]
  changeOrders     ProjectChangeOrder[]
  activity         ProjectActivity[]
  workOrders       ProjectWorkOrder[]
  violations       ProjectViolation[]

  @@index([orgId, status])
  @@index([orgId, buildingId])
  @@index([orgId, category])
  @@map("projects")
}

model ProjectMilestone {
  id          String          @id @default(cuid())
  projectId   String
  name        String
  description String?         @db.Text
  status      MilestoneStatus @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, status])
  @@map("project_milestones")
}

model ProjectBudgetLine {
  id          String   @id @default(cuid())
  projectId   String
  category    String
  description String?
  estimated   Decimal  @db.Decimal(12, 2)
  actual      Decimal? @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_budget_lines")
}

model ProjectChangeOrder {
  id          String            @id @default(cuid())
  projectId   String
  title       String
  description String?           @db.Text
  amount      Decimal           @db.Decimal(12, 2)
  status      ChangeOrderStatus @default(DRAFT)
  requestedAt DateTime          @default(now())
  approvedAt  DateTime?
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_change_orders")
}

model ProjectActivity {
  id        String   @id @default(cuid())
  projectId String
  userId    String?
  action    String
  detail    String?  @db.Text
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("project_activities")
}

model ProjectWorkOrder {
  projectId   String
  workOrderId String
  linkedAt    DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, workOrderId])
  @@map("project_work_orders")
}

model ProjectViolation {
  projectId   String
  violationId String
  linkedAt    DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, violationId])
  @@map("project_violations")
}

// ── Atlas Communicate ──

enum OutreachTrigger {
  DAYS_10
  DAYS_30
  DAYS_60
  MANUAL
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum OutreachChannel {
  SMS
  EMAIL
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
  RESPONDED
}

model OutreachCampaign {
  id          String          @id @default(cuid())
  orgId       String
  name        String
  triggerType OutreachTrigger
  status      CampaignStatus  @default(DRAFT)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  messages    OutreachMessage[]

  @@index([orgId])
  @@map("outreach_campaigns")
}

model OutreachMessage {
  id          String           @id @default(cuid())
  campaignId  String
  tenantId    String
  channel     OutreachChannel
  direction   MessageDirection
  body        String           @db.Text
  status      MessageStatus    @default(PENDING)
  sentAt      DateTime?
  deliveredAt DateTime?
  respondedAt DateTime?
  aiGenerated Boolean          @default(false)
  createdAt   DateTime         @default(now())
  campaign    OutreachCampaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([tenantId])
  @@index([status])
  @@map("outreach_messages")
}

// ── Collections Protocol & Stage Tracking ─────────────────────

model CollectionStage {
  id                    String             @id @default(cuid())
  tenantId              String             @unique
  orgId                 String
  stage                 Int
  stageEnteredAt        DateTime           @default(now())
  daysPastDue           Int
  actionDueBy           DateTime?
  actionOverdue         Boolean            @default(false)
  lastActionAt          DateTime?
  lastActionType        String?
  nextRecommendedAction String?
  status                String             @default("active")
  updatedAt             DateTime           @updatedAt
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([orgId])
  @@index([tenantId])
  @@index([actionOverdue])
  @@index([stage])
  @@map("collection_stages")
}

model CollectionAction {
  id                   String    @id @default(cuid())
  tenantId             String
  orgId                String
  stageId              String
  actionType           String
  actionDate           DateTime
  outcome              String
  promisedPaymentDate  DateTime?
  promisedPaymentAmount Decimal? @db.Decimal(10, 2)
  promiseBroken        Boolean   @default(false)
  notes                String?   @db.Text
  staffId              String
  createdAt            DateTime  @default(now())
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  staff                User      @relation("CollectionActionStaff", fields: [staffId], references: [id])

  @@index([tenantId])
  @@index([orgId])
  @@index([actionDate])
  @@map("collection_actions")
}

model CollectionProtocol {
  id                      String  @id @default(cuid())
  orgId                   String  @unique
  stage2TriggerDays       Int     @default(6)
  stage3TriggerDays       Int     @default(15)
  stage4TriggerDays       Int     @default(31)
  stage5TriggerDays       Int     @default(60)
  stage2ActionWindowDays  Int     @default(4)
  stage3ActionWindowDays  Int     @default(3)
  stage4ActionWindowDays  Int     @default(4)
  enableEmailAlerts       Boolean @default(true)
  updatedAt               DateTime @updatedAt

  @@map("collection_protocols")
}

// ── Document Management ────────────────────────────────────────

enum DocumentType {
  LEASE
  VIOLATION_CERTIFICATE
  INSURANCE_CERT
  PERMIT
  INSPECTION_REPORT
  LEGAL_DOCUMENT
  OTHER
}

model Document {
  id             String       @id @default(cuid())
  organizationId String?
  buildingId     String?
  unitId         String?
  tenantId       String?
  docType        DocumentType
  fileName       String
  fileUrl        String
  fileSize       Int?
  uploadedById   String
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  building       Building?    @relation(fields: [buildingId], references: [id])
  unit           Unit?        @relation(fields: [unitId], references: [id])
  tenant         Tenant?      @relation(fields: [tenantId], references: [id])
  uploadedBy     User         @relation(fields: [uploadedById], references: [id])

  @@index([organizationId])
  @@index([buildingId])
  @@index([unitId])
  @@index([tenantId])
  @@index([docType])
  @@map("documents")
}

// ── Atlas Comms ───────────────────────────────────────────────

enum ConversationType {
  direct
  group
  work_order
  violation
  legal_case
  building
  unit
  turnover
  collections_case
  incident
}

enum ConversationVisibility {
  internal
  restricted
}

enum ConversationMemberRole {
  member
  admin
  moderator
}

enum NotificationLevel {
  all
  mentions_only
  muted
}

enum MessageType {
  standard
  status_update
  blocker
  approval_request
  vendor_update
  internal_note
  system_event
}

model Conversation {
  id                String                 @id @default(cuid())
  orgId             String
  type              ConversationType
  title             String?
  createdByUserId   String?
  relatedEntityType String?
  relatedEntityId   String?
  buildingId        String?
  visibility        ConversationVisibility @default(internal)
  isArchived        Boolean                @default(false)
  archivedAt        DateTime?
  lastMessageAt     DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  members           ConversationMember[]
  messages          Message[]
  pinnedMessages    PinnedMessage[]

  @@index([orgId])
  @@index([orgId, type])
  @@index([relatedEntityType, relatedEntityId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationMember {
  id                String                 @id @default(cuid())
  conversationId    String
  userId            String
  role              ConversationMemberRole  @default(member)
  joinedAt          DateTime               @default(now())
  leftAt            DateTime?
  notificationLevel NotificationLevel      @default(all)
  lastReadMessageId String?
  lastReadAt        DateTime?

  conversation      Conversation           @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@map("conversation_members")
}

model Message {
  id                String              @id @default(cuid())
  conversationId    String
  senderUserId      String?
  body              String              @db.Text
  messageType       MessageType         @default(standard)
  replyToMessageId  String?
  metadata          Json?
  isSystemGenerated Boolean             @default(false)
  editedAt          DateTime?
  deletedAt         DateTime?
  createdAt         DateTime            @default(now())

  conversation      Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments       MessageAttachment[]
  reactions         MessageReaction[]
  mentions          MessageMention[]
  pinnedAs          PinnedMessage[]

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([senderUserId])
  @@map("messages")
}

model MessageAttachment {
  id          String   @id @default(cuid())
  messageId   String
  fileUrl     String
  fileName    String
  mimeType    String
  fileSize    Int
  imageWidth  Int?
  imageHeight Int?
  createdAt   DateTime @default(now())

  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachments")
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  reaction  String
  createdAt DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, reaction])
  @@index([messageId])
  @@map("message_reactions")
}

model MessageMention {
  id              String   @id @default(cuid())
  messageId       String
  mentionedUserId String
  createdAt       DateTime @default(now())

  message         Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([mentionedUserId])
  @@map("message_mentions")
}

model PinnedMessage {
  id              String       @id @default(cuid())
  conversationId  String
  messageId       String
  pinnedByUserId  String
  pinnedAt        DateTime     @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message         Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([conversationId, messageId])
  @@index([conversationId])
  @@map("pinned_messages")
}

// ── Intelligence — Decision Log & Attention ───────────────────

model DecisionLog {
  id                 String    @id @default(cuid())
  orgId              String
  userId             String
  module             String    // collections | vacancy | violations | work_orders | leases | utilities
  entityType         String    // tenant | building | unit | work_order | violation | lease | meter
  entityId           String
  recommendationCode String    // decision engine code e.g. "COL_LEGAL_REVIEW"
  recommendationText String    @db.Text
  severity           String    // low | medium | high | critical
  outcome            String    @default("shown") // shown | acted | overridden | dismissed | expired
  userAction         String?   // what the user actually did (free text or action code)
  outcomeRecordedAt  DateTime?
  resultAfter7d      String?   // improved | unchanged | worsened | resolved
  resultAfter30d     String?
  resultRecordedAt   DateTime?
  shownAt            DateTime  @default(now())
  createdAt          DateTime  @default(now())

  @@index([orgId])
  @@index([entityType, entityId])
  @@index([module, recommendationCode])
  @@index([outcome])
  @@index([userId])
  @@map("decision_logs")
}
